# Copy file ini menjadi `.env` untuk konfigurasi lokal:
# cp .env.example .env
#
# `.env` sengaja tidak di-commit supaya secret/kredensial production tidak bocor.

PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-in-production

# Default development memakai database JSON lokal (`database/users.json`).
DB_TYPE=json

# Untuk production MongoDB, ganti DB_TYPE dan isi URI di `.env` lokal/hosting.
# DB_TYPE=mongodb
# MONGODB_URI=mongodb://localhost:27017/youzapi
# MONGODB_DB=youzapi
