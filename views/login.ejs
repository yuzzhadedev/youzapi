<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title><%= title || 'Masuk · YOUZ API' %></title>
<meta property="og:description" content="Modern API platform untuk developer dan bisnis modern.">
<meta property="og:image" content="https://raw.githubusercontent.com/uploader762/dat3/main/uploads/3fae03-1776528467067.jpg">
<meta property="og:type" content="website">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --red:#c0392b;
  --red2:#e74c3c;
  --bg:#111111;
  --bg2:#181818;
  --bg3:#1e1e1e;
  --border:rgba(255,255,255,0.07);
  --border-red:rgba(192,57,43,0.35);
  --text:#f1f5f9;
  --muted:#888888;
  --dim:#444444;
  --error:#e74c3c;
  --error-bg:rgba(231,76,60,0.08);
  --success:#2ecc71;
  --success-bg:rgba(46,204,113,0.08);
}

body{
  font-family:'Barlow',sans-serif;
  background:var(--bg);
  color:var(--text);
  min-height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  padding:20px;
  position:relative;
  overflow-y:auto;
}

/* GRID BG */
body::before{
  content:'';
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);
  background-size:60px 60px;
  pointer-events:none;
  z-index:0;
}

/* RED GLOW TOP-LEFT */
body::after{
  content:'';
  position:fixed;
  top:-100px;left:-100px;
  width:400px;height:400px;
  background:radial-gradient(circle,rgba(192,57,43,0.12) 0%,transparent 70%);
  pointer-events:none;
  z-index:0;
}

.auth-wrap{
  width:100%;
  max-width:400px;
  display:flex;
  flex-direction:column;
  gap:0;
  position:relative;
  z-index:2;
  animation:fadeUp .5s ease both;
}

@keyframes fadeUp{
  from{opacity:0;transform:translateY(32px)}
  to{opacity:1;transform:translateY(0)}
}

/* HEADER BAR */
.auth-header{
  background:var(--red);
  padding:20px 28px 18px;
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.auth-logo{
  display:flex;
  align-items:center;
  gap:10px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;
  font-weight:900;
  letter-spacing:1px;
  color:#fff;
  text-transform:uppercase;
}

.logo-sq{
  width:18px;height:18px;
  background:rgba(255,255,255,0.3);
  flex-shrink:0;
}

.auth-header-title{
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:2px;
  color:rgba(255,255,255,0.7);
  text-transform:uppercase;
}

/* AVATAR */
.auth-avatar-row{
  background:var(--bg2);
  border-left:1px solid var(--border);
  border-right:1px solid var(--border);
  padding:24px 28px;
  display:flex;
  align-items:center;
  gap:16px;
  border-bottom:1px solid var(--border-red);
}

.avatar-img{
  width:56px;height:56px;
  background-image:url('https://raw.githubusercontent.com/uploader762/dat3/main/uploads/3fae03-1776528467067.jpg');
  background-size:cover;
  background-position:center;
  flex-shrink:0;
  border:2px solid var(--border-red);
}

.avatar-text{}
.avatar-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:22px;
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:.5px;
  line-height:1;
  margin-bottom:4px;
}
.avatar-sub{
  font-family:'Space Mono',monospace;
  font-size:10px;
  color:var(--muted);
  letter-spacing:1px;
}

/* CARD */
.auth-card{
  background:var(--bg2);
  border:1px solid var(--border);
  border-top:none;
  padding:28px 28px 32px;
  display:flex;
  flex-direction:column;
  gap:20px;
}

/* NOTIF */
.notif{
  padding:12px 14px;
  font-family:'Space Mono',monospace;
  font-size:11px;
  font-weight:700;
  letter-spacing:.5px;
  display:none;
  align-items:center;
  gap:10px;
  border-left:3px solid;
}
.notif.error{background:var(--error-bg);border-color:var(--error);color:var(--error);display:flex;}
.notif.success{background:var(--success-bg);border-color:var(--success);color:var(--success);display:flex;}
.notif i{font-size:16px;flex-shrink:0;}

/* FIELD */
.field{display:flex;flex-direction:column;gap:6px;}
.field-label{
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  color:var(--muted);
  letter-spacing:2px;
  text-transform:uppercase;
}

.field input{
  font-family:'Barlow',sans-serif;
  background:var(--bg3);
  border:1px solid var(--border);
  border-bottom:2px solid var(--dim);
  padding:13px 14px;
  font-size:15px;
  color:var(--text);
  outline:none;
  transition:border-color .2s,background .2s;
  width:100%;
}
.field input:focus{
  border-color:var(--border);
  border-bottom-color:var(--red);
  background:#1a1a1a;
}
.field input::placeholder{color:var(--dim);font-size:14px;}

/* BTN */
.btn{
  border:none;
  padding:15px 20px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:16px;
  font-weight:800;
  letter-spacing:2px;
  text-transform:uppercase;
  cursor:pointer;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:10px;
  transition:background .2s,transform .1s;
  position:relative;
  overflow:hidden;
}
.btn-primary{background:var(--red);color:#fff;}
.btn-primary:hover{background:var(--red2);}
.btn-primary:active{transform:scale(.98);}
.btn-full{width:100%;}
.btn:disabled{opacity:.55;cursor:not-allowed;}

/* FOOTER LINK */
.auth-footer{
  background:var(--bg3);
  border:1px solid var(--border);
  border-top:none;
  padding:14px 28px;
  text-align:center;
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--muted);
  letter-spacing:.5px;
}
.auth-footer a{
  color:var(--red2);
  text-decoration:none;
  font-weight:700;
  transition:color .15s;
}
.auth-footer a:hover{color:#fff;}

/* SPINNER */
.loading-spinner{
  display:inline-block;
  width:14px;height:14px;
  border:2px solid rgba(255,255,255,0.3);
  border-top-color:#fff;
  border-radius:50%;
  animation:spin .6s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}

@media(max-width:480px){
  body{padding:0;align-items:flex-start;}
  .auth-wrap{max-width:100%;min-height:100vh;display:flex;flex-direction:column;}
  .auth-card{flex:1;}
}
</style>
</head>
<body>
<div class="auth-wrap">

  <div class="auth-header">
    <div class="auth-logo">
      <div class="logo-sq"></div>
      YOUZ API
    </div>
    <span class="auth-header-title">MASUK</span>
  </div>

  <div class="auth-avatar-row">
    <div class="avatar-img"></div>
    <div class="avatar-text">
      <div class="avatar-title">Selamat Datang</div>
      <div class="avatar-sub">// MASUK UNTUK LANJUT</div>
    </div>
  </div>

  <div class="auth-card">
    <div class="notif" id="notif"></div>

    <div class="field">
      <span class="field-label">// username</span>
      <input type="text" id="username" placeholder="masukkan username" autocomplete="username">
    </div>

    <div class="field">
      <span class="field-label">// kata sandi</span>
      <input type="password" id="password" placeholder="••••••••" autocomplete="current-password">
    </div>

    <button class="btn btn-primary btn-full" id="loginBtn">
      <i class="bi bi-arrow-right"></i> MASUK
    </button>
  </div>

  <div class="auth-footer">
    belum punya akun? <a href="/registro">daftar sekarang →</a>
  </div>

</div>

<script>
const notif = document.getElementById('notif');

function showNotif(msg, tipo) {
  notif.className = 'notif ' + tipo;
  notif.innerHTML = `<i class="bi bi-${tipo === 'error' ? 'x-circle' : 'check-circle'}"></i> ${msg}`;
  setTimeout(() => {
    if (notif.className === 'notif ' + tipo) {
      notif.style.opacity = '0';
      setTimeout(() => { notif.className = 'notif'; notif.style.opacity = ''; }, 300);
    }
  }, 4000);
}

document.getElementById('loginBtn').addEventListener('click', async () => {
  const username = document.getElementById('username').value.trim();
  const password = document.getElementById('password').value;
  if (!username || !password) { showNotif('isi semua kolom', 'error'); return; }

  const btn = document.getElementById('loginBtn');
  const orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<span class="loading-spinner"></span> LOADING...';

  try {
    const r = await fetch('/api/login', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ username, password }) });
    const d = await r.json();
    if (d.success) {
      showNotif('berhasil! mengalihkan...', 'success');
      window.location.href = '/dash';
    } else {
      showNotif(d.message || 'kredensial tidak valid', 'error');
      btn.disabled = false; btn.innerHTML = orig;
      document.getElementById('password').focus();
    }
  } catch {
    showNotif('kesalahan koneksi. coba lagi', 'error');
    btn.disabled = false; btn.innerHTML = orig;
  }
});

document.addEventListener('keydown', e => { if (e.key === 'Enter') { const b = document.getElementById('loginBtn'); if (!b.disabled) b.click(); }});
document.getElementById('username').addEventListener('keypress', e => { if (e.key === 'Enter') document.getElementById('password').focus(); });
</script>
</body>
</html>
