<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title><%= title || 'Profil · YOUZ API' %></title>
<meta property="og:description" content="Modern API platform untuk developer dan bisnis modern.">
<meta property="og:image" content="https://raw.githubusercontent.com/uploader762/dat3/main/uploads/3fae03-1776528467067.jpg">
<meta property="og:type" content="website">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#c0392b;--red2:#e74c3c;
  --bg:#111111;--bg2:#181818;--bg3:#1e1e1e;
  --border:rgba(255,255,255,0.07);--border-red:rgba(192,57,43,0.3);
  --text:#f1f5f9;--muted:#888888;--dim:#444444;
  --accent:#c0392b;--success:#2ecc71;--error:#e74c3c;
}

body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);overflow:hidden;display:flex;flex-direction:column;height:100dvh;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.02) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}

header{
  display:flex;align-items:center;gap:0;
  height:52px;flex-shrink:0;
  border-bottom:1px solid var(--border);
  background:var(--bg2);
  position:relative;z-index:50;
}
.back-btn{
  display:flex;align-items:center;justify-content:center;
  width:52px;height:52px;
  border-right:1px solid var(--border);
  color:var(--muted);font-size:18px;
  text-decoration:none;
  transition:background .15s,color .15s;
  flex-shrink:0;
}
.back-btn:hover{background:var(--bg3);color:var(--text);}
.header-left{
  display:flex;align-items:center;
  padding:0 16px;
  border-right:3px solid var(--red);
  height:100%;
}
.page-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:16px;font-weight:800;letter-spacing:1px;text-transform:uppercase;
}
.header-right{
  margin-left:auto;
  display:flex;align-items:center;
  padding:0 14px;
  font-family:'Space Mono',monospace;
  font-size:9px;color:var(--dim);letter-spacing:1px;
}

.page{flex:1;overflow-y:auto;overflow-x:hidden;scrollbar-width:none;position:relative;z-index:1;}
.page::-webkit-scrollbar{display:none;}

.inner{max-width:500px;margin:0 auto;padding:20px 16px 40px;display:flex;flex-direction:column;gap:1px;background:var(--border);}

/* flash */
.flash{padding:12px 16px;font-family:'Space Mono',monospace;font-size:11px;border-left:3px solid;margin-bottom:0;}
.flash-success{background:rgba(46,204,113,.06);border-color:var(--success);color:var(--success);}
.flash-error{background:rgba(231,76,60,.06);border-color:var(--error);color:var(--error);}

/* HERO CARD */
.profile-hero{background:var(--bg2);}

.hero-banner{
  height:clamp(70px,18vw,100px);
  background-size:cover;background-position:center;
  background-color:var(--bg3);
  position:relative;
}
.hero-banner::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(24,24,24,0.9));}

.hero-body{
  padding:0 20px 20px;
  display:flex;flex-direction:column;align-items:flex-start;
  position:relative;
}

.hero-av-row{
  display:flex;align-items:flex-end;gap:14px;
  margin-top:clamp(-22px,-6vw,-28px);
  margin-bottom:12px;
  position:relative;z-index:2;
}

.hero-avatar{
  width:clamp(56px,14vw,72px);height:clamp(56px,14vw,72px);
  background-size:cover;background-position:center;
  border:3px solid var(--bg2);
  outline:2px solid var(--border-red);
  flex-shrink:0;
}

.hero-badges-inline{display:flex;gap:6px;flex-wrap:wrap;padding-bottom:4px;}

.hero-name{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(20px,5vw,26px);font-weight:900;
  text-transform:uppercase;letter-spacing:.5px;
  display:flex;align-items:center;gap:8px;flex-wrap:wrap;
  margin-bottom:6px;
}
.hero-name i{font-size:clamp(14px,4vw,16px);}

.badge{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 8px;
  font-family:'Space Mono',monospace;
  font-size:9px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  border:1px solid;
}
.badge-level{background:rgba(192,57,43,.1);border-color:var(--border-red);color:var(--red2);}
.badge-premium{background:rgba(241,196,15,.07);border-color:rgba(241,196,15,.25);color:#f1c40f;}
.badge-admin{background:rgba(192,57,43,.15);border-color:rgba(192,57,43,.4);color:#ff6b6b;}

/* XP BAR */
.xp-section{
  background:var(--bg2);
  padding:14px 20px;
  border-top:1px solid var(--border);
}
.xp-row{display:flex;justify-content:space-between;margin-bottom:6px;}
.xp-label{font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;}
.xp-bar-wrap{height:3px;background:var(--bg3);}
.xp-bar-fill{height:100%;background:var(--red);transition:width .6s ease;}

/* STATS */
.stat-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:var(--border);
}
.stat-box{
  background:var(--bg2);padding:16px 18px;
}
.stat-icon{font-size:18px;color:var(--red);opacity:.7;margin-bottom:6px;display:block;}
.stat-label{font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;}
.stat-val{font-family:'Barlow Condensed',sans-serif;font-size:clamp(22px,6vw,28px);font-weight:900;margin-top:2px;letter-spacing:-.5px;}

/* KEY BOX */
.key-section{background:var(--bg2);padding:14px 18px;}
.section-label{font-family:'Space Mono',monospace;font-size:9px;color:var(--dim);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.key-box{
  background:rgba(192,57,43,.06);border:1px solid var(--border-red);
  padding:11px 14px;display:flex;align-items:center;gap:10px;
}
.key-val{
  font-family:'Space Mono',monospace;font-size:12px;font-weight:700;color:var(--red2);
  flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
}
.key-copy{color:var(--muted);cursor:pointer;font-size:15px;transition:color .15s;flex-shrink:0;}
.key-copy:hover{color:var(--red2);}

/* EDIT BTN */
.edit-section{background:var(--bg2);padding:14px 18px;}
.btn-edit{
  display:flex;align-items:center;justify-content:center;gap:10px;
  width:100%;padding:13px;
  background:var(--bg3);
  border:1px solid var(--border);
  font-family:'Barlow Condensed',sans-serif;
  font-size:15px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;
  color:var(--muted);text-decoration:none;
  transition:background .15s,color .15s,border-color .15s;
}
.btn-edit:hover{background:var(--red);border-color:var(--red);color:#fff;}

/* TOAST */
.toast{
  position:fixed;bottom:24px;left:50%;
  transform:translateX(-50%) translateY(80px);
  background:var(--bg2);border:1px solid var(--border);border-left:3px solid var(--success);
  color:var(--success);padding:10px 20px;
  font-family:'Space Mono',monospace;font-size:11px;font-weight:700;
  z-index:200;transition:transform .25s;pointer-events:none;white-space:nowrap;
}
.toast.show{transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<div class="toast" id="toast"></div>

<header>
  <a href="/dash" class="back-btn"><i class="bi bi-arrow-left"></i></a>
  <div class="header-left">
    <span class="page-title">PROFIL</span>
  </div>
  <div class="header-right">@<%= user.username %></div>
</header>

<div class="page">
  <div class="inner">

    <% if (success_msg && success_msg.length) { %>
    <div class="flash flash-success"><i class="bi bi-check-circle"></i> <%= success_msg %></div>
    <% } %>
    <% if (error_msg && error_msg.length) { %>
    <div class="flash flash-error"><i class="bi bi-x-circle"></i> <%= error_msg %></div>
    <% } %>

    <!-- HERO -->
    <div class="profile-hero">
      <div class="hero-banner" <% if(user.capa){ %>style="background-image:url('<%= user.capa %>');"<% } %>></div>
      <div class="hero-body">
        <div class="hero-av-row">
          <div class="hero-avatar" style="background-image:url('<%= user.foto %>');"></div>
          <div class="hero-badges-inline">
            <span class="badge badge-level"><i class="bi bi-layers"></i> LV <%= user.level || 1 %></span>
            <% if (user.premium) { %><span class="badge badge-premium"><i class="bi bi-lightning-charge-fill"></i> PREMIUM</span><% } %>
            <% if (user.adm) { %><span class="badge badge-admin"><i class="bi bi-shield-fill"></i> ADMIN</span><% } %>
          </div>
        </div>
        <div class="hero-name">
          <%= user.username %>
          <% if (user.adm) { %><i class="bi bi-patch-check-fill" style="color:var(--red2);"></i><% } %>
          <% if (user.premium) { %><i class="bi bi-lightning-charge-fill" style="color:#f1c40f;"></i><% } %>
        </div>
      </div>
    </div>

    <!-- XP -->
    <div class="xp-section">
      <div class="xp-row">
        <span class="xp-label">// XP PROGRESS</span>
        <span class="xp-label"><%= user.xp || 0 %> / <%= (user.level||1)*50 %> XP</span>
      </div>
      <div class="xp-bar-wrap">
        <div class="xp-bar-fill" style="width:<%= Math.min(Math.round(((user.xp||0)/((user.level||1)*50))*100),100) %>%;"></div>
      </div>
    </div>

    <!-- STATS -->
    <div class="stat-grid">
      <div class="stat-box">
        <i class="bi bi-activity stat-icon"></i>
        <div class="stat-label">// REQUESTS</div>
        <div class="stat-val"><%= user.totalRequests || 0 %></div>
      </div>
      <div class="stat-box">
        <i class="bi bi-trophy stat-icon"></i>
        <div class="stat-label">// XP TOTAL</div>
        <div class="stat-val"><%= user.xp || 0 %></div>
      </div>
    </div>

    <!-- API KEY -->
    <div class="key-section">
      <div class="section-label">// API KEY</div>
      <div class="key-box">
        <span class="key-val" id="apiKey"><%= user.key %></span>
        <i class="bi bi-copy key-copy" id="copyKey"></i>
      </div>
    </div>

    <!-- EDIT BTN -->
    <div class="edit-section">
      <a href="/perfil/editar" class="btn-edit">
        <i class="bi bi-pencil"></i> EDIT PROFIL
      </a>
    </div>

  </div>
</div>

<script>
document.getElementById('copyKey').addEventListener('click', () => {
  navigator.clipboard.writeText(document.getElementById('apiKey').textContent).then(() => {
    const t = document.getElementById('toast');
    t.innerHTML = '<i class="bi bi-check"></i> KEY DISALIN';
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2000);
  });
});
</script>
</body>
</html>
