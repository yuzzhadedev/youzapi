<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title><%= title || 'EDIT PROFIL · YOUZ API' %></title>
<meta property="og:description" content="Modern API platform untuk developer dan bisnis modern.">
<meta property="og:image" content="https://raw.githubusercontent.com/uploader762/dat3/main/uploads/3fae03-1776528467067.jpg">
<meta property="og:type" content="website">
<link rel="stylesheet" href="/css/main.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
<style>
body { overflow: hidden; display: flex; flex-direction: column; }

header {
  padding: clamp(12px,4vw,16px) clamp(14px,5vw,20px);
  display: flex; align-items: center; gap: 14px;
  border-bottom: 1px solid var(--border);
  background: rgba(8,11,18,0.85);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  flex-shrink: 0; z-index: 50;
}
.back-btn {
  color: var(--text-muted); font-size: 20px;
  text-decoration: none; display: flex; align-items: center; transition: color 0.2s;
}
.back-btn:hover { color: var(--text); }
.page-title { font-size: clamp(14px,4vw,15px); font-weight: 600; }

.page {
  flex: 1; overflow-y: auto; overflow-x: hidden;
  scrollbar-width: none; -webkit-overflow-scrolling: touch;
}
.page::-webkit-scrollbar { display: none; }

.inner {
  max-width: 500px; margin: 0 auto;
  padding: clamp(14px,4vw,20px) clamp(12px,4vw,16px) clamp(24px,6vw,36px);
  display: flex; flex-direction: column; gap: clamp(12px,3vw,16px);
}

.preview-card {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: clamp(14px,4vw,20px); padding: clamp(14px,4vw,18px);
  display: flex; align-items: center; gap: 14px;
}
.preview-av {
  width: clamp(48px,13vw,60px); height: clamp(48px,13vw,60px);
  border-radius: clamp(12px,4vw,16px);
  border: 2px solid rgba(139,92,246,0.35);
  background-size: cover; background-position: center; flex-shrink: 0;
  transition: border-color 0.2s;
}
.preview-name { font-size: clamp(14px,4vw,16px); font-weight: 600; }
.preview-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

.fields { display: flex; flex-direction: column; gap: clamp(12px,3vw,14px); }
</style>
</head>
<body>

<div class="toast" id="toast"></div>

<header>
  <a href="/profil" class="back-btn"><i class="bi bi-arrow-left"></i></a>
  <span class="page-title">edit profil</span>
</header>

<div class="page">
  <div class="inner">

    <div class="preview-card">
      <div class="preview-av" id="previewAv" style="background-image:url('<%= user.foto %>');"></div>
      <div>
        <div class="preview-name"><%= user.username %></div>
        <div class="preview-sub">pratinjau</div>
      </div>
    </div>

    <div class="fields">
      <div class="field">
        <span class="field-label">nama pengguna</span>
        <input type="text" id="username" value="<%= user.username %>" maxlength="20">
      </div>
      <div class="field">
        <span class="field-label">URL foto</span>
        <input type="url" id="foto" value="<%= user.foto %>" placeholder="https://...">
      </div>
      <div class="field">
        <span class="field-label">URL sampul</span>
        <input type="url" id="capa" value="<%= user.capa || '' %>" placeholder="https://...">
      </div>
      <% if (user.premium || user.adm) { %>
      <div class="field">
        <span class="field-label">kunci API personalizada</span>
        <input type="text" id="key" value="<%= user.key %>">
      </div>
      <% } %>
    </div>

    <button class="btn btn-primary btn-full" id="saveBtn">
      <i class="bi bi-check-lg"></i> simpan perubahan
    </button>

  </div>
</div>

<script>
function showToast(msg, tipo) {
  const t = document.getElementById('toast');
  t.className = 'toast ' + tipo + ' show';
  t.innerHTML = `<i class="bi bi-${tipo === 'success' ? 'check-circle' : 'x-circle'}"></i> ${msg}`;
  setTimeout(() => t.classList.remove('show'), 2500);
}

document.getElementById('foto').addEventListener('input', e => {
  if (e.target.value) document.getElementById('previewAv').style.backgroundImage = `url('${e.target.value}')`;
});

document.getElementById('saveBtn').addEventListener('click', async () => {
  const btn = document.getElementById('saveBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="bi bi-hourglass-split"></i> menyimpan...';

  const payload = {
    username: document.getElementById('username').value.trim(),
    foto: document.getElementById('foto').value.trim(),
    capa: document.getElementById('capa').value.trim(),
  };
  const keyField = document.getElementById('key');
  if (keyField) payload.key = keyField.value.trim();

  try {
    const r = await fetch('/api/perfil/editar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const d = await r.json();
    if (d.success) {
      showToast('profil atualizado!', 'success');
      setTimeout(() => window.location.href = '/profil', 1000);
    } else {
      showToast(d.message || 'gagal menyimpan', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-check-lg"></i> simpan perubahan';
    }
  } catch {
    showToast('kesalahan koneksi', 'error');
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check-lg"></i> simpan perubahan';
  }
});
</script>
</body>
</html>
