function closeMenu(){document.getElementById('menuOverlay').classList.remove('open');}

/* ---- CHART HELPER (pure canvas, no deps) ---- */
function drawBarChart(canvasId, data, color, maxOverride){
  const canvas = document.getElementById(canvasId);
  if(!canvas) return;
  const dpr = window.devicePixelRatio || 1;
  const W = canvas.parentElement.offsetWidth;
  const H = 160;
  canvas.width = W * dpr;
  canvas.height = H * dpr;
  canvas.style.width = W + 'px';
  canvas.style.height = H + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(dpr, dpr);

  const max = maxOverride || Math.max(...data.map(d=>d.val)) * 1.15;
  const padL=40, padR=8, padT=10, padB=28;
  const chartW = W - padL - padR;
  const chartH = H - padT - padB;
  const barW = (chartW / data.length) * 0.6;
  const gap = (chartW / data.length) * 0.4;

  // Grid lines + Y labels
  ctx.strokeStyle = 'rgba(255,255,255,0.05)';
  ctx.lineWidth = 1;
  ctx.font = `700 9px 'Space Mono', monospace`;
  ctx.fillStyle = '#555';
  ctx.textAlign = 'right';
  for(let i=0;i<=4;i++){
    const y = padT + chartH - (i/4)*chartH;
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W-padR, y); ctx.stroke();
    const label = formatK((max*(i/4)));
    ctx.fillText(label, padL-4, y+3);
  }

  // Bars
  data.forEach((d, i) => {
    const barH = (d.val / max) * chartH;
    const x = padL + i * (chartW / data.length) + gap/2;
    const y = padT + chartH - barH;
    ctx.fillStyle = color;
    ctx.fillRect(x, y, barW, barH);
  });

  // X labels
  ctx.fillStyle = '#555';
  ctx.textAlign = 'center';
  ctx.font = `700 9px 'Space Mono', monospace`;
  data.forEach((d, i) => {
    const x = padL + i * (chartW / data.length) + (chartW/data.length)/2;
    ctx.fillText(d.label, x, H - 6);
  });
}

function formatK(n){
  if(n>=1000) return (n/1000).toFixed(0)+'K';
  return Math.round(n).toString();
}

/* ---- DATA ---- */
const reqData = [
  {label:'21/5',val:27200},{label:'22/5',val:25100},{label:'23/5',val:24300},
  {label:'24/5',val:28600},{label:'25/5',val:30100},{label:'26/5',val:26400},{label:'27/5',val:6200}
];
const atkData = [
  {label:'21/5',val:860},{label:'22/5',val:1580},{label:'23/5',val:290},
  {label:'24/5',val:1310},{label:'25/5',val:840},{label:'26/5',val:1630},{label:'27/5',val:60}
];

/* ---- REALTIME REQUESTS ---- */
const realtimeSeed = [
  {ago:'2s ago', status:200, path:'GET /api/s/pinterest', ip:'47.237.22.x', latency:'1988ms', ua:'python-requests/2.22.0'},
  {ago:'18s ago', status:200, path:'GET /api/games/tebakkata', ip:'45.251.7.x', latency:'64ms', ua:'Mozilla/5.0'},
  {ago:'18s ago', status:200, path:'GET /api/s/pinterest', ip:'114.5.146.x', latency:'1921ms', ua:'axios/1.15.0'},
  {ago:'20s ago', status:200, path:'GET /api/s/pinterest', ip:'47.237.22.x', latency:'4166ms', ua:'python-requests/2.22.0'},
  {ago:'34s ago', status:200, path:'GET /api/berita/cnbcindonesia', ip:'114.122.20.x', latency:'363ms', ua:'Dart/3.11 (dart:io)'},
];

function renderRealtime(list){
  const el = document.getElementById('realtimeList');
  el.innerHTML = list.map(r => {
    const sc = r.status >= 500 ? 's5xx' : r.status >= 400 ? 's4xx' : 's200';
    return `<div class="req-item">
      <div class="req-top">
        <span class="req-ago">${r.ago}</span>
        <span class="req-status ${sc}">${r.status}</span>
      </div>
      <div class="req-path">${r.path}</div>
      <div class="req-meta">
        <span>IP: <b>${r.ip}</b></span>
        <span>Latency: <b>${r.latency}</b></span>
        <span>UA: <b>${r.ua}</b></span>
      </div>
    </div>`;
  }).join('');
}

/* ---- TOP ENDPOINTS ---- */
const allEndpoints = [
  {path:'/api/berita/cnbcindonesia',req:'4.794',sr:99.9},{path:'/api/m/brat',req:'3.528',sr:99.9},
  {path:'/api/s/pinterest',req:'2.175',sr:100},{path:'/api/d/facebook',req:'1.250',sr:67.6},
  {path:'/api/ai/duckai',req:'1.181',sr:78.9},{path:'/api/ai/gemini',req:'1.034',sr:71.2},
  {path:'/api/games/tebakkata',req:'987',sr:99.5},{path:'/api/d/instagram',req:'876',sr:82.3},
  {path:'/api/s/google',req:'754',sr:98.1},{path:'/api/d/tiktok',req:'712',sr:88.4},
  {path:'/api/berita/detik',req:'698',sr:97.8},{path:'/api/ai/deepseekr1',req:'645',sr:91.2},
  {path:'/api/anime/info',req:'601',sr:99.1},{path:'/api/d/twitter',req:'589',sr:75.4},
  {path:'/api/tools/qr',req:'544',sr:100},{path:'/api/m/capcut',req:'510',sr:88.9},
];

let currentPage = 1;
const perPage = 5;
const totalPages = Math.ceil(allEndpoints.length / perPage);

function renderTable(page){
  const start = (page-1)*perPage;
  const rows = allEndpoints.slice(start, start+perPage);
  const tbody = document.getElementById('epTableBody');
  tbody.innerHTML = rows.map((ep, i) => {
    const rank = start+i+1;
    const srClass = ep.sr >= 95 ? 'high' : ep.sr >= 75 ? 'mid' : 'low';
    return `<tr onclick="alert('Live detail: ${ep.path}')">
      <td class="num">${rank}</td>
      <td class="path">${ep.path}</td>
      <td class="req">${ep.req}</td>
      <td class="sr ${srClass}">${ep.sr}%</td>
    </tr>`;
  }).join('');
  document.getElementById('pageInfo').textContent = `PAGE ${page}/${totalPages}`;
  document.getElementById('prevBtn').disabled = page <= 1;
  document.getElementById('nextBtn').disabled = page >= totalPages;
}

function changePage(dir){
  currentPage = Math.max(1, Math.min(totalPages, currentPage + dir));
  renderTable(currentPage);
}

/* ---- LIVE COUNTER SIMULATION ---- */
let totalReqCount = 2970689;
let totalErrCount = 300467;
let totalAtkCount = 1029672;

function fmt(n){ return n.toLocaleString('id-ID'); }

function tickCounters(){
  totalReqCount += Math.floor(Math.random()*8)+1;
  totalErrCount += Math.random() > 0.85 ? 1 : 0;
  totalAtkCount += Math.random() > 0.92 ? 1 : 0;
  document.getElementById('totalReq').textContent = fmt(totalReqCount);
  document.getElementById('totalErr').textContent = fmt(totalErrCount);
  document.getElementById('totalAtk').textContent = fmt(totalAtkCount);
  const rate = ((totalReqCount - totalErrCount) / totalReqCount * 100).toFixed(1);
  document.getElementById('successRate').textContent = rate + '%';

  // rotate realtime list
  const paths = ['/api/s/pinterest','/api/m/brat','/api/ai/duckai','/api/berita/cnbcindonesia','/api/d/tiktok','/api/games/tebakkata','/api/d/instagram'];
  const uas = ['python-requests/2.22.0','Mozilla/5.0','axios/1.15.0','Dart/3.11 (dart:io)','okhttp/4.9.0'];
  const ips = ['47.237.22.x','114.5.146.x','45.251.7.x','114.122.20.x','103.41.7.x'];
  realtimeSeed.pop();
  realtimeSeed.unshift({
    ago: 'just now',
    status: Math.random() > 0.1 ? 200 : (Math.random() > 0.5 ? 404 : 500),
    path: 'GET ' + paths[Math.floor(Math.random()*paths.length)],
    ip: ips[Math.floor(Math.random()*ips.length)],
    latency: (Math.floor(Math.random()*2000)+50) + 'ms',
    ua: uas[Math.floor(Math.random()*uas.length)]
  });
  renderRealtime(realtimeSeed);
}

/* ---- INIT ---- */
function init(){
  drawBarChart('reqChart', reqData, '#c0392b');
  drawBarChart('atkChart', atkData, '#922b21');
  renderRealtime(realtimeSeed);
  renderTable(1);
  setInterval(tickCounters, 3000);
}

window.addEventListener('load', init);
window.addEventListener('resize', ()=>{
  drawBarChart('reqChart', reqData, '#c0392b');
  drawBarChart('atkChart', atkData, '#922b21');
});
</script>
