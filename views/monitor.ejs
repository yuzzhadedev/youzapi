<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monitor — API SIPUTZX</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#c0392b;--red2:#e74c3c;
  --bg:#111111;--bg2:#181818;--bg3:#1e1e1e;
  --border:rgba(255,255,255,0.07);
  --text:#ffffff;--muted:#888888;--dim:#555555;
  --green:#2ecc71;--yellow:#f39c12;
}
html{scroll-behavior:smooth}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(17,17,17,0.97);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;text-decoration:none;color:var(--text);}
.logo-sq{width:20px;height:20px;background:var(--red);flex-shrink:0;}
.nav-menu-btn{width:44px;height:44px;border:1px solid var(--border);background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:5px;transition:background .2s;}
.nav-menu-btn:hover{background:var(--bg3);}
.nav-menu-btn span{display:block;width:20px;height:2px;background:var(--text);}

/* PAGE CONTENT */
.content{position:relative;z-index:1;padding:0 16px 0;max-width:680px;margin:0 auto;}

/* SYSTEM MONITOR HERO CARD */
.monitor-hero{
  margin:24px 0 0;
  border:1px solid var(--border);
  background:var(--bg2);
  padding:28px 24px 24px;
}
.monitor-hero-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(32px,9vw,48px);
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:.5px;
  margin-bottom:16px;
  line-height:1;
}
.monitor-hero-title span{color:var(--red);}
.live-badge{
  display:inline-flex;align-items:center;gap:8px;
  border:1px solid var(--border);background:var(--bg3);
  padding:6px 14px;
  font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:2px;
}
.live-dot{width:8px;height:8px;background:var(--green);border-radius:50%;animation:pulse 1.5s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.85)}}

/* STATS GRID */
.stats-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:var(--border);
  margin:1px 0 0;
}
.stat-card{
  background:var(--bg2);padding:20px 20px 18px;
  border:none;
  transition:background .15s;
}
.stat-card:hover{background:var(--bg3);}
.stat-card-label{
  font-family:'Space Mono',monospace;font-size:9px;font-weight:700;
  letter-spacing:2px;color:var(--muted);text-transform:uppercase;
  margin-bottom:10px;
}
.stat-card-val{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(28px,8vw,38px);font-weight:900;
  line-height:1;letter-spacing:-.5px;margin-bottom:4px;
}
.stat-card-val.white{color:var(--text);}
.stat-card-val.yellow{color:var(--yellow);}
.stat-card-val.red{color:var(--red2);}
.stat-card-val.green{color:var(--green);}
.stat-card-sub{font-size:12px;color:var(--dim);font-style:italic;}

/* SECTION WRAPPER */
.section{
  margin:1px 0 0;background:var(--bg2);
  border:1px solid var(--border);border-top:none;
  padding:20px 20px;
}
.section-head{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;
}
.section-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;font-weight:800;text-transform:uppercase;letter-spacing:.5px;
}
.section-tag{
  font-family:'Space Mono',monospace;font-size:9px;font-weight:700;
  letter-spacing:2px;color:var(--dim);
}
.section-tag.green{color:var(--green);}

/* NODE STATUS */
.node-row{
  display:flex;align-items:center;gap:12px;
  border:1px solid var(--border);background:var(--bg3);
  padding:12px 14px;
}
.node-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.node-dot.healthy{background:var(--green);box-shadow:0 0 8px rgba(46,204,113,.5);animation:pulse 1.5s infinite;}
.node-dot.degraded{background:var(--yellow);}
.node-dot.down{background:var(--red2);}
.node-name{
  font-family:'Space Mono',monospace;font-size:12px;font-weight:700;
  letter-spacing:1px;flex:1;
}
.node-meta{
  display:flex;align-items:center;gap:16px;
  font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);
}
.node-meta .healthy{color:var(--green);}

/* LIVE TRAFFIC SIGNALS */
.traffic-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:var(--border);
}
.traffic-box{
  background:var(--bg3);padding:14px 16px;
}
.traffic-label{font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.traffic-val{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(22px,7vw,30px);font-weight:900;
}

/* STATUS CODE ROW */
.code-grid{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:var(--border);
}
.code-box{background:var(--bg3);padding:14px 16px;}
.code-label{font-family:'Space Mono',monospace;font-size:9px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:6px;}
.code-val{
  font-family:'Space Mono',monospace;
  font-size:clamp(12px,3.5vw,15px);font-weight:700;
  line-height:1.5;
}

/* REALTIME REQUESTS */
.req-item{
  border:1px solid var(--border);background:var(--bg3);
  padding:14px 16px;margin-bottom:1px;
  transition:background .15s;cursor:pointer;
}
.req-item:hover{background:#222;}
.req-item:last-child{margin-bottom:0;}
.req-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.req-ago{font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:1px;}
.req-status{
  font-family:'Space Mono',monospace;font-size:13px;font-weight:700;
  padding:2px 6px;
}
.req-status.s200{color:var(--green);}
.req-status.s4xx{color:var(--yellow);}
.req-status.s5xx{color:var(--red2);}
.req-path{
  font-family:'Space Mono',monospace;font-size:13px;font-weight:700;
  margin-bottom:8px;word-break:break-all;
}
.req-meta{
  display:flex;flex-wrap:wrap;gap:12px;
  font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);
}
.req-meta span b{color:var(--text);}

/* CHART */
.chart-wrap{position:relative;width:100%;}
.chart-canvas{width:100%;display:block;}
.chart-labels{
  display:flex;justify-content:space-between;
  font-family:'Space Mono',monospace;font-size:9px;color:var(--dim);
  letter-spacing:.5px;margin-top:6px;padding:0 2px;
}

/* ERROR RATE BAR */
.rate-row{
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:10px;
}
.rate-label{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:1px;}
.rate-label.green{color:var(--green);}
.rate-label.yellow{color:var(--yellow);}
.rate-pct{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;}
.rate-pct.green{color:var(--green);}
.rate-pct.yellow{color:var(--yellow);}
.rate-bar-wrap{height:6px;background:var(--bg3);display:flex;gap:2px;margin-bottom:0;}
.rate-bar-fill{height:100%;transition:width .6s ease;}
.rate-bar-fill.green{background:var(--green);}
.rate-bar-fill.yellow{background:var(--yellow);}

/* TOP ENDPOINTS TABLE */
.ep-table{width:100%;border-collapse:collapse;}
.ep-table thead tr{border-bottom:1px solid var(--border);}
.ep-table th{
  font-family:'Space Mono',monospace;font-size:9px;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;color:var(--dim);
  padding:8px 8px;text-align:left;
}
.ep-table th:last-child{text-align:right;}
.ep-table tbody tr{
  border-bottom:1px solid rgba(255,255,255,.04);
  cursor:pointer;transition:background .12s;
}
.ep-table tbody tr:hover{background:rgba(255,255,255,.03);}
.ep-table td{
  font-family:'Space Mono',monospace;font-size:11px;
  padding:12px 8px;color:var(--muted);
}
.ep-table td.num{color:var(--dim);font-size:10px;}
.ep-table td.path{color:var(--text);font-size:11px;word-break:break-all;}
.ep-table td.req{font-weight:700;color:var(--text);}
.ep-table td.sr{font-weight:700;text-align:right;}
.ep-table td.sr.high{color:var(--green);}
.ep-table td.sr.mid{color:var(--yellow);}
.ep-table td.sr.low{color:var(--red2);}

.table-pagination{
  display:flex;align-items:center;justify-content:space-between;
  padding:12px 8px;border-top:1px solid var(--border);
  margin-top:0;
}
.page-info{font-family:'Space Mono',monospace;font-size:10px;color:var(--dim);letter-spacing:1px;}
.page-btns{display:flex;gap:8px;}
.page-btn{
  font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:1px;
  padding:6px 14px;border:1px solid var(--border);background:var(--bg3);
  color:var(--muted);cursor:pointer;transition:background .15s,color .15s,border-color .15s;
}
.page-btn:hover{background:var(--red);border-color:var(--red);color:#fff;}
.page-btn:disabled{opacity:.3;cursor:not-allowed;}

/* ======================== FOOTER (sama persis dengan index.html) ======================== */
footer{position:relative;z-index:1;border-top:1px solid var(--border);padding:48px 24px 32px;margin-top:0;}
.footer-brand{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:900;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;}
.footer-status{display:inline-flex;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:1px;color:#2ecc71;margin-bottom:16px;}
.footer-tagline{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:32px;max-width:300px;}
.social-row{display:flex;gap:1px;flex-wrap:wrap;margin-bottom:40px;}
.social-btn{width:48px;height:48px;border:1px solid var(--border);background:var(--bg2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .2s,border-color .2s;text-decoration:none;color:var(--muted);}
.social-btn:hover{background:var(--bg3);border-color:var(--red);color:var(--text);}
.social-btn svg{width:18px;height:18px;}
.footer-cols{display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:40px;}
.footer-col-title{font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--dim);margin-bottom:16px;}
.footer-col a{display:block;font-size:14px;color:var(--muted);text-decoration:none;margin-bottom:10px;transition:color .15s;}
.footer-col a:hover{color:var(--text);}
.footer-col a.has-dot{display:flex;align-items:center;gap:8px;}
.footer-col a.has-dot::after{content:'■';font-size:8px;color:#2ecc71;}
.footer-bottom{border-top:1px solid var(--border);padding-top:24px;display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;}
.footer-copy{font-family:'Space Mono',monospace;font-size:11px;color:var(--dim);}
.footer-links{display:flex;gap:16px;align-items:center;}
.footer-links a{font-size:12px;color:var(--dim);text-decoration:none;transition:color .15s;}
.footer-links a:hover{color:var(--text);}

/* MENU OVERLAY */
.menu-overlay{position:fixed;inset:0;background:var(--bg);z-index:200;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);}
.menu-overlay.open{transform:translateX(0);}
.menu-top{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;border-bottom:1px solid var(--border);}
.menu-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;color:var(--muted);}
.menu-close{width:44px;height:44px;border:1px solid var(--border);background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--text);transition:background .2s;}
.menu-close:hover{background:var(--red);}
.menu-links{flex:1;display:flex;flex-direction:column;justify-content:center;padding:32px 32px;gap:4px;}
.menu-link{font-family:'Barlow Condensed',sans-serif;font-size:clamp(48px,14vw,72px);font-weight:900;text-transform:uppercase;color:var(--dim);text-decoration:none;line-height:1;transition:color .15s;display:block;}
.menu-link:hover,.menu-link.active{color:var(--text);}
.menu-divider{height:1px;background:var(--border);margin:16px 0;}
.menu-secondary{display:flex;flex-direction:column;gap:4px;}
.menu-sec-link{font-family:'Barlow Condensed',sans-serif;font-size:clamp(24px,7vw,36px);font-weight:700;text-transform:uppercase;color:var(--dim);text-decoration:none;line-height:1.2;transition:color .15s;}
.menu-sec-link:hover{color:var(--text);}
.menu-bottom{padding:24px 32px;border-top:1px solid var(--border);}
.btn-join{display:block;width:100%;background:var(--red);color:#fff;text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;padding:18px;transition:background .2s;}
.btn-join:hover{background:var(--red2);}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">
    <div class="logo-sq"></div>
    API SIPUTZX
  </a>
  <button class="nav-menu-btn" onclick="openMenu()" aria-label="Menu">
    <span></span><span></span>
  </button>
</nav>

<div class="content">

  <!-- HERO -->
  <div class="monitor-hero">
    <div class="monitor-hero-title">SYSTEM <span>MONITOR</span></div>
    <div class="live-badge"><span class="live-dot"></span> LIVE</div>
  </div>

  <!-- STATS GRID -->
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-card-label">TOTAL REQUESTS</div>
      <div class="stat-card-val white" id="totalReq">2.970.689</div>
      <div class="stat-card-sub">Realtime</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-label">TOTAL ERRORS</div>
      <div class="stat-card-val yellow" id="totalErr">300.467</div>
      <div class="stat-card-sub">5xx dominant</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-label">TOTAL ATTACKS</div>
      <div class="stat-card-val red" id="totalAtk">1.029.672</div>
      <div class="stat-card-sub">Guard layer</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-label">SUCCESS RATE</div>
      <div class="stat-card-val yellow" id="successRate">88.9%</div>
      <div class="stat-card-sub">Response quality</div>
    </div>
  </div>

  <!-- NODE STATUS -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">NODE STATUS</span>
      <span class="section-tag green">1/1 HEALTHY</span>
    </div>
    <div class="node-row">
      <div class="node-dot healthy"></div>
      <span class="node-name">LOCAL-NODE</span>
      <div class="node-meta">
        <span id="nodeLatency">7ms</span>
        <span>conn <span id="nodeConn">0</span></span>
        <span class="healthy">healthy</span>
      </div>
    </div>
  </div>

  <!-- LIVE TRAFFIC SIGNALS -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">LIVE TRAFFIC SIGNALS</span>
      <span class="section-tag green">LIVE</span>
    </div>
    <div class="traffic-grid">
      <div class="traffic-box">
        <div class="traffic-label">UPTIME</div>
        <div class="traffic-val" id="uptime">23h</div>
      </div>
      <div class="traffic-box">
        <div class="traffic-label">ACTIVE CONNS</div>
        <div class="traffic-val" id="activeConn">0</div>
      </div>
      <div class="traffic-box" style="margin-top:1px;">
        <div class="traffic-label">RECENT AVG LATENCY</div>
        <div class="traffic-val" id="avgLatency">1319.1ms</div>
      </div>
      <div class="traffic-box" style="margin-top:1px;">
        <div class="traffic-label">FAILOVER RATE</div>
        <div class="traffic-val" id="failover">2.7%</div>
      </div>
    </div>
  </div>

  <!-- STATUS CODE BREAKDOWN -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">STATUS BREAKDOWN</span>
      <span class="section-tag">LIVE</span>
    </div>
    <div class="code-grid">
      <div class="code-box">
        <div class="code-label">2XX / 4XX / 5XX</div>
        <div class="code-val">
          <span style="color:var(--green);">1645681</span> /
          <span style="color:var(--yellow);">978342</span> /
          <span style="color:var(--red2);">179304</span>
        </div>
      </div>
      <div class="code-box">
        <div class="code-label">AVG NODE FAIL</div>
        <div class="code-val" style="font-size:clamp(18px,5vw,24px);color:var(--yellow);font-family:'Barlow Condensed',sans-serif;font-weight:900;">17.01%</div>
      </div>
    </div>
  </div>

  <!-- REQUEST HISTORY CHART -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">REQUEST HISTORY</span>
      <span class="section-tag">DAILY</span>
    </div>
    <div class="chart-wrap">
      <canvas class="chart-canvas" id="reqChart" height="160"></canvas>
    </div>
    <div class="chart-labels" id="reqLabels"></div>
  </div>

  <!-- ATTACK HISTORY CHART -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">ATTACK HISTORY</span>
      <span class="section-tag">DAILY</span>
    </div>
    <div class="chart-wrap">
      <canvas class="chart-canvas" id="atkChart" height="160"></canvas>
    </div>
    <div class="chart-labels" id="atkLabels"></div>
  </div>

  <!-- ERROR RATE OVERVIEW -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">ERROR RATE OVERVIEW</span>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <div class="rate-row">
        <span class="rate-label green">SUCCESS</span>
        <span class="rate-pct green">88.9%</span>
      </div>
      <div class="rate-row">
        <span class="rate-label yellow">ERRORS</span>
        <span class="rate-pct yellow">11.1%</span>
      </div>
      <div class="rate-bar-wrap">
        <div class="rate-bar-fill green" style="width:88.9%;"></div>
        <div class="rate-bar-fill yellow" style="width:11.1%;"></div>
      </div>
    </div>
  </div>

  <!-- LAST 5 REALTIME REQUESTS -->
  <div class="section">
    <div class="section-head">
      <span class="section-title">LAST 5 REALTIME REQUESTS</span>
      <span class="section-tag">IP MASKED</span>
    </div>
    <div id="realtimeList"></div>
  </div>

  <!-- TOP ENDPOINTS -->
  <div class="section" style="padding-bottom:0;">
    <div class="section-head" style="padding-bottom:0;">
      <span class="section-title">TOP ENDPOINTS</span>
      <span class="section-tag">CLICK ROW FOR LIVE DETAIL</span>
    </div>
    <div style="overflow-x:auto;">
      <table class="ep-table">
        <thead>
          <tr>
            <th>#</th>
            <th>ENDPOINT</th>
            <th>REQ</th>
            <th>SR%</th>
          </tr>
        </thead>
        <tbody id="epTableBody"></tbody>
      </table>
    </div>
    <div class="table-pagination">
      <span class="page-info" id="pageInfo">PAGE 1/83</span>
      <div class="page-btns">
        <button class="page-btn" id="prevBtn" onclick="changePage(-1)" disabled>PREV 5</button>
        <button class="page-btn" id="nextBtn" onclick="changePage(1)">NEXT 5</button>
      </div>
    </div>
  </div>

</div><!-- /content -->

<!-- FOOTER — SAMA PERSIS DENGAN INDEX.HTML -->
<footer>
  <div class="footer-brand">API SIPUTZX</div>
  <div class="footer-status">
    <span class="live-dot" style="width:7px;height:7px;"></span>
    ONLINE
  </div>
  <p class="footer-tagline">Membangun ekosistem developer yang lebih cepat, terbuka, dan inklusif.</p>

