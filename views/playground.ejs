          <div class="ep-actions">
            <button class="btn-execute" onclick="executeApi(this, '/api/ai/glm47flash', ['q'])">▶ EXECUTE</button>
            <button class="btn-copy-url" onclick="copyUrl(this, '/api/ai/glm47flash', ['q'])">COPY URL</button>
          </div>
          <pre class="result-box" id="result-3"></pre>
        </div>
      </div>

      <div class="ep-item" data-name="phi phi2 ai microsoft">
