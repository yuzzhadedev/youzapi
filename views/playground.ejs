            <button class="btn-execute" onclick="executeApi(this, '/api/ai/gptoss120b', ['q'])">▶ EXECUTE</button>
            <button class="btn-copy-url" onclick="copyUrl(this, '/api/ai/gptoss120b', ['q'])">COPY URL</button>
          </div>
          <pre class="result-box" id="result-2"></pre>
