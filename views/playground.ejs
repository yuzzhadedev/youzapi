    <div class="menu-divider"></div>
    <div class="menu-secondary">
      <a href="#" class="menu-sec-link">TERMS</a>
      <a href="#" class="menu-sec-link">PRIVACY</a>
    </div>
  </div>
  <div class="menu-bottom">
    <a href="#" class="btn-join">JOIN COMMUNITY</a>
  </div>
</div>

<script>
const BASE = '';

function openMenu(){document.getElementById('menuOverlay').classList.add('open');}
function closeMenu(){document.getElementById('menuOverlay').classList.remove('open');}
const ACCOUNT_API_TOKEN = <%- JSON.stringify(user?.key || '') %>;
function getApiToken(){
  return (ACCOUNT_API_TOKEN || '').trim();
}

function applyEndpointStatuses(endpoints){
  const m=new Map((endpoints||[]).map(e=>[e.rota,(e.status||'ready').toLowerCase()]));
  document.querySelectorAll('.ep-item').forEach((item)=>{
    const path = item.querySelector('.ep-path')?.textContent?.trim();
    if(!path) return;
    const st = m.get(path) || 'ready';
    item.setAttribute('data-status', st);
  });
  document.querySelectorAll('.ep-badge[data-status-for]').forEach((el)=>{
    const st=m.get(el.getAttribute('data-status-for'))||'ready';
    el.className=`ep-badge ${st}`;
    el.textContent=st.toUpperCase();
  });
}


function toggleEp(el){
  const body = el.nextElementSibling;
  const wasOpen = el.classList.contains('open');
  document.querySelectorAll('.ep-header.open').forEach(h=>{h.classList.remove('open');h.nextElementSibling.classList.remove('open');});
  if(!wasOpen){
    el.classList.add('open');
    body.classList.add('open');
  }
}

function splitParamList(value){
  return (value || '').split(',').map(v=>v.trim()).filter(Boolean);
}

function getParamNames(body){
  return splitParamList(body?.dataset?.params);
}

function getOptionalParamNames(body){
  return splitParamList(body?.dataset?.optionalParams);
}

function getAllParamNames(body){
  return [...new Set([...getParamNames(body), ...getOptionalParamNames(body)])];
}

function getParamsFromBody(body){
  const params = {};
  getAllParamNames(body).forEach(name=>{
    const inp = body.querySelector(`[data-param="${name}"]`);
    if(inp && inp.value.trim()) params[name] = inp.value.trim();
  });
  return params;
}

function getParams(btn, paramNames){
  const body = btn.closest('.ep-body');
  const params = {};
  paramNames.forEach(name=>{
    const inp = body.querySelector(`[data-param="${name}"]`);
    if(inp && inp.value.trim()) params[name] = inp.value.trim();
  });
  return params;
}

function buildUrl(path, params){
  const qs = Object.entries(params || {}).map(([k,v])=>`${k}=${encodeURIComponent(v)}`).join('&');
  return `${BASE}${path}${qs ? '?'+qs : ''}`;
}

function getSelectedMethod(body){
  return body.querySelector('.method-tab.active')?.dataset?.method || 'GET';
}

function getActiveTab(body){
  return body.querySelector('.result-tab.active')?.dataset?.tab || 'preview';
}

function getResultBox(target){
  const body = target.closest('.ep-body');
  return body.querySelector('.result-box');
}

function missingParams(body){
  const params = getParamsFromBody(body);
  return getParamNames(body).filter(name=>!params[name]);
}

function buildCurl(method, path, params, token){
  const url = method === 'GET' ? buildUrl(path, params) : `${BASE}${path}`;
  const headers = [];
  if(token) headers.push(`-H "Authorization: Bearer ${token}"`);
  if(method === 'POST') headers.push('-H "Content-Type: application/json"');
  const jsonBody = JSON.stringify(params || {});
  const escapedBody = jsonBody.replace(/'/g, "'\\''");
  const body = method === 'POST' ? ` -d '${escapedBody}'` : '';
  return [`curl -X ${method} "${url}"`, ...headers].join(' ') + body;
}

function getActiveResultText(body){
  const cache = body._playgroundResult;
  if(!cache) return '';
  const active = getActiveTab(body);
  if(active === 'curl') return cache.curl || '';
  if(active === 'headers') return cache.headers || '// Header respons belum tersedia';
  return cache.preview || '';
}

function updateResultMeta(body){
  const cache = body._playgroundResult || {};
  const codeEl = body.querySelector('.result-code');
  const msEl = body.querySelector('.result-ms');
  const code = Number(cache.statusCode || 0);
  const ok = code >= 200 && code < 400;
  if(codeEl){
    codeEl.className = `result-code ${ok ? 'ok' : 'err'}`;
    codeEl.textContent = code ? `${code} ${ok ? 'OK' : 'ERR'}` : 'ERR';
  }
  if(msEl) msEl.textContent = `${Math.max(0, Math.round(cache.durationMs || 0))}ms`;
}

function renderCachedResult(body){
  const resultBox = body.querySelector('.result-box');
  const cache = body._playgroundResult;
  if(!cache) return;
  body.querySelector('.result-tabs')?.classList.add('show');
  updateResultMeta(body);
  resultBox.className = `result-box show${cache.error ? ' error' : ''}`;
  resultBox.textContent = getActiveResultText(body);
}

async function executeBody(body, triggerBtn = null){
  const item = body.closest('.ep-item');
  const status = item?.getAttribute('data-status') || 'ready';
  const resultBox = body.querySelector('.result-box');
  const startedAt = performance.now();
  if(triggerBtn){
    triggerBtn.classList.add('loading');
    triggerBtn.textContent = 'MEMPROSES';
  }
  if (status === 'maintenance' || status === 'closed') {
    body._playgroundResult = {
      error: true,
      statusCode: status === 'maintenance' ? 503 : 403,
      durationMs: performance.now() - startedAt,
      preview: JSON.stringify({ success: false, message: status === 'maintenance' ? 'Layanan sedang dirapikan' : 'Layanan sedang ditutup', code: status === 'maintenance' ? 503 : 403 }, null, 2),
      headers: '// Permintaan ditahan dari Playground',
      curl: '// Curl belum tersedia karena layanan belum siap'
    };
    renderCachedResult(body);
    if(triggerBtn){
      triggerBtn.classList.remove('loading');
      triggerBtn.textContent = 'EXECUTE';
    }
    return;
  }

  const missing = missingParams(body);
  if (missing.length) {
    const code = 400;
    body._playgroundResult = {
      error: true,
      statusCode: code,
      durationMs: performance.now() - startedAt,
      preview: JSON.stringify({ status: false, message: `Parameter "${missing[0]}" perlu diisi`, code }, null, 2),
      headers: '// Header tidak tersedia karena permintaan belum dikirim',
      curl: buildCurl(getSelectedMethod(body), body.dataset.path, getParamsFromBody(body), getApiToken())
    };
    renderCachedResult(body);
    if(triggerBtn){
      triggerBtn.classList.remove('loading');
      triggerBtn.textContent = 'EXECUTE';
    }
    return;
  }

  const path = body.dataset.path;
  const params = getParamsFromBody(body);
  const method = getSelectedMethod(body);
  const token = getApiToken();
  const headers = token ? { Authorization: `Bearer ${token}` } : {};
  const fetchOptions = { method, headers };
  const url = method === 'GET' ? buildUrl(path, params) : `${BASE}${path}`;

  if(method === 'POST') {
    fetchOptions.headers = { ...headers, 'Content-Type': 'application/json' };
    fetchOptions.body = JSON.stringify(params);
  }

  body.querySelector('.result-tabs')?.classList.add('show');
  resultBox.className = 'result-box show';
  resultBox.textContent = '// Memproses permintaan...';

  try{
    const res = await fetch(url, fetchOptions);
    const contentType = res.headers.get('content-type') || '';
    const data = contentType.includes('application/json') ? await res.json() : await res.text();
    const responseHeaders = [...res.headers.entries()].map(([key, value]) => `${key}: ${value}`).join('\n');
    body._playgroundResult = {
      error: !res.ok,
      statusCode: res.status,
      durationMs: performance.now() - startedAt,
      preview: typeof data === 'string' ? data : JSON.stringify(data, null, 2),
      headers: responseHeaders || '// Header respons belum tersedia',
      curl: buildCurl(method, path, params, token)
    };
  }catch(e){
    body._playgroundResult = {
      error: true,
      statusCode: 0,
      durationMs: performance.now() - startedAt,
      preview: JSON.stringify({ status: false, message: e.message, code: 0, url }, null, 2),
      headers: '// Permintaan berhenti sebelum header respons diterima',
      curl: buildCurl(method, path, params, token)
    };
  }

  renderCachedResult(body);
  if(triggerBtn){
    triggerBtn.classList.remove('loading');
    triggerBtn.textContent = 'EXECUTE';
  }
}

function resetEndpointResult(body, clearParams = false){
  body._playgroundResult = null;
  body.querySelector('.result-box').className = 'result-box';
  body.querySelector('.result-box').textContent = '';
  body.querySelector('.result-tabs')?.classList.remove('show');
  const codeEl = body.querySelector('.result-code');
  const msEl = body.querySelector('.result-ms');
  if(codeEl){ codeEl.className = 'result-code'; codeEl.textContent = '---'; }
  if(msEl) msEl.textContent = '0ms';
  body.querySelectorAll('.result-tab').forEach((tab)=>tab.classList.toggle('active', tab.dataset.tab === 'preview'));
  if(clearParams) body.querySelectorAll('.param-input').forEach((input)=>{ input.value = ''; });
}

function clearEndpoint(btn){
  resetEndpointResult(btn.closest('.ep-body'), true);
}

async function executeApi(btn, path, paramNames){
  await executeBody(btn.closest('.ep-body'), btn);
}

function syncMethodBadge(body){
  const method = getSelectedMethod(body);
  const badge = body.closest('.ep-item')?.querySelector('.ep-method');
  if(!badge) return;
  badge.textContent = method;
  badge.classList.toggle('post', method === 'POST');
}

function copyResult(btn){
  const body = btn.closest('.ep-body');
  const value = getActiveResultText(body);
  if(!value) return;
  navigator.clipboard.writeText(value).then(()=>{
    const original = btn.innerHTML;
    btn.textContent = 'OK';
    btn.style.color = '#2ecc71';
    setTimeout(()=>{btn.innerHTML = original;btn.style.color='';}, 1200);
  });
}

function initPlaygroundInteractions(){
  document.querySelectorAll('.ep-body').forEach((body)=>{
    syncMethodBadge(body);
    body.querySelectorAll('.param-input').forEach((input)=>{
      input.addEventListener('input',()=>resetEndpointResult(body));
      input.addEventListener('change',()=>resetEndpointResult(body));
    });
  });

  document.addEventListener('click',(e)=>{
    if(e.target.classList.contains('result-tab')){
      const body=e.target.closest('.ep-body');
      body.querySelectorAll('.result-tab').forEach(t=>t.classList.remove('active'));
      e.target.classList.add('active');
      renderCachedResult(body);
      return;
    }
    if(e.target.classList.contains('method-tab')){
      const body=e.target.closest('.ep-body');
      body.querySelectorAll('.method-tab').forEach(t=>t.classList.remove('active'));
      e.target.classList.add('active');
      syncMethodBadge(body);
      resetEndpointResult(body);
    }
  });
}

async function sinkronEndpointPlugin(){
  try{
    const res = await fetch('/api/plugins/list');
    const data = await res.json();
    const endpoints = data.data?.endpoints || [];
    const available = new Set(endpoints.map(e => e.rota));
    applyEndpointStatuses(endpoints);
    document.querySelectorAll('.ep-item').forEach((item)=>{
      const path = item.querySelector('.ep-path')?.textContent?.trim();
      if (!path) return;
      const btn = item.querySelector('.btn-execute');
      const st = item.getAttribute('data-status') || 'ready';
      if (!available.has(path)) { item.style.opacity='0.45'; if(btn){btn.disabled=true; btn.textContent='TIDAK TERSEDIA';} return; }
      if (st === 'maintenance') { item.style.opacity='0.6'; if(btn){btn.disabled=true; btn.textContent='DIRAPIKAN';} return; }
      if (st === 'closed') { item.style.opacity='0.45'; if(btn){btn.disabled=true; btn.textContent='DITUTUP';} return; }
      item.style.opacity=''; if(btn){btn.disabled=false; btn.textContent='EXECUTE';}
    });
  }catch(e){}
}

function initLoader(){
  const loader = document.getElementById('pgLoader');
  if (!loader) return;
  window.addEventListener('load', () => {
    loader.classList.add('hide');
    setTimeout(() => loader.remove(), 600);
  });
}

initLoader();
initPlaygroundInteractions();
sinkronEndpointPlugin();

function filterEndpoints(val){
  const q = val.toLowerCase();
  document.querySelectorAll('.ep-item').forEach(item=>{
    const text = item.getAttribute('data-name') || '';
    const path = item.querySelector('.ep-path')?.textContent || '';
    const match = (text + path).toLowerCase().includes(q);
    item.style.display = match ? '' : 'none';
  });
  document.querySelectorAll('.endpoint-group').forEach(grp=>{
    const visible = [...grp.querySelectorAll('.ep-item')].some(i=>i.style.display!=='none');
    grp.style.display = visible ? '' : 'none';
  });
}
</script>
</body>
