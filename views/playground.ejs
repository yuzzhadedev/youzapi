        </div>
        <div class="ep-body">
          <p class="ep-desc">Tanya jawab berbasis Al-Kitab menggunakan AI.</p>
          <div class="param-label">PARAMETERS</div>
          <div class="param-row">
            <span class="param-name">q</span>
            <input type="text" class="param-input" placeholder="Masukkan pertanyaan..." data-param="q">
          </div>
          <div class="ep-actions">
            <button class="btn-execute" onclick="executeApi(this, '/api/ai/bibleai', ['q'])">▶ EXECUTE</button>
            <button class="btn-copy-url" onclick="copyUrl(this, '/api/ai/bibleai', ['q'])">COPY URL</button>
