            <button class="btn-copy-url" onclick="copyUrl(this, '/api/ai/qwq32b', ['q'])">COPY URL</button>
          </div>
          <pre class="result-box" id="result-5"></pre>
        </div>
      </div>

      <div class="ep-item" data-name="deepseek deepseekr1 r1 ai">
        <div class="ep-header" onclick="toggleEp(this)">
          <span class="ep-method">GET</span>
          <span class="ep-path">/api/ai/deepseekr1</span>
          <span class="ep-name">DEEPSEEK R1</span>
          <div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div>
        </div>
        <div class="ep-body">
          <p class="ep-desc">DeepSeek R1 — model reasoning canggih dengan chain-of-thought.</p>
          <div class="param-label">PARAMETERS</div>
          <div class="param-row">
            <span class="param-name">q</span>
            <input type="text" class="param-input" placeholder="Masukkan pertanyaan..." data-param="q">
          </div>
