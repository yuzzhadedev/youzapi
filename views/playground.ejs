<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>API Console V1 — YOUZ API</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#c0392b;--red2:#e74c3c;
  --bg:#111111;--bg2:#181818;--bg3:#1e1e1e;
  --border:rgba(255,255,255,0.07);
  --text:#ffffff;--muted:#888888;--dim:#555555;
  --blue:#2980b9;--blue2:#3498db;
}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;min-height:100vh;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}

.pg-loader{position:fixed;inset:0;z-index:300;display:flex;align-items:center;justify-content:center;background:rgba(17,17,17,0.98);backdrop-filter:blur(10px);transition:opacity .35s ease,visibility .35s ease;}
.pg-loader.hide{opacity:0;visibility:hidden;}
.pg-loader-inner{width:min(520px,92vw);padding:28px 18px;border:1px solid var(--border);background:rgba(24,24,24,0.7);text-align:center;}
.pg-loader-mark{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:14px;}
.pg-loader-ring{width:26px;height:26px;border-radius:999px;border:2px solid rgba(255,255,255,0.12);border-top-color:var(--red);animation:pgspin .85s linear infinite;}
.pg-loader-sq{width:16px;height:16px;background:var(--red);animation:pgpulse .9s ease-in-out infinite;}
.pg-loader-title{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:900;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;}
.pg-loader-sub{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--dim);}
@keyframes pgspin{to{transform:rotate(360deg)}}
@keyframes pgpulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.72);opacity:.65}}

.badge-btn{border:1px solid var(--border);background:var(--bg3);color:var(--text);padding:8px 10px;font-size:10px;font-weight:700;letter-spacing:1px;cursor:pointer;text-transform:uppercase;}

nav{position:sticky;top:0;z-index:100;background:rgba(17,17,17,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;text-decoration:none;color:var(--text);}
.logo-sq{width:20px;height:20px;background:var(--red);flex-shrink:0;}
.nav-menu-btn{width:44px;height:44px;border:1px solid var(--border);background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:5px;}
.nav-menu-btn span{display:block;width:20px;height:2px;background:var(--text);}

.page-hero{
  position:relative;z-index:1;
  text-align:center;
  padding:42px 20px 34px;
  border-bottom:1px solid var(--border);
}
.page-hero h1{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(32px,9vw,56px);
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:1px;
  margin-bottom:10px;
}
.page-hero h1 .red{color:var(--red);}
.page-hero h1 .version{
  font-size:clamp(14px,4vw,22px);
  color:var(--dim);
  vertical-align:middle;
  margin-left:8px;
}
.page-hero-sub{
  font-size:10px;
  font-weight:600;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--dim);
}

.console-wrap{
  position:relative;z-index:1;
  padding:24px 16px 80px;
  max-width:640px;
  margin:0 auto;
}

.search-box{
  position:sticky;
  top:64px;
  z-index:80;
  display:flex;
  align-items:center;
  gap:12px;
  border:1px solid var(--border);
  background:var(--bg2);
  padding:12px 14px;
  margin-bottom:32px;
}
.search-box svg{width:18px;height:18px;color:var(--dim);flex-shrink:0;}
.search-input{
  flex:1;
  background:none;
  border:none;
  outline:none;
  font-family:'Space Mono',monospace;
  font-size:12px;
  font-weight:700;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--muted);
}
.search-input::placeholder{color:var(--dim);}

.endpoint-group{
  margin-bottom:32px;
}

.group-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:12px;
  padding-bottom:8px;
  border-left:3px solid var(--red);
  padding-left:12px;
}
.group-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.5px;
}
.group-count{
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:1px;
  color:var(--dim);
}

.ep-list{
  display:flex;
  flex-direction:column;
  gap:-1px;
  background:var(--border);
}

.ep-item{
  background:var(--bg);
  border:none;
}

.ep-header{
  display:flex;
  align-items:center;
  gap:12px;
  padding:12px 12px;
  cursor:pointer;
  transition:background .15s;
  user-select:none;
}
.ep-header:hover{background:var(--bg2);}
.ep-header.open{background:var(--bg3);}

.ep-method{
  font-family:'Barlow Condensed',sans-serif;
  font-size:12px;
  font-weight:800;
  letter-spacing:1px;
  padding:3px 8px;
  background:var(--blue);
  color:#fff;
  flex-shrink:0;
  min-width:48px;
  text-align:center;
  transition:background .15s,box-shadow .15s;
}
.ep-method.post{background:#1e7e34;box-shadow:0 0 14px rgba(46,204,113,.16);}
.ep-path{
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--muted);
  flex:1;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}
.ep-name{
  font-size:11px;
  font-weight:600;
  letter-spacing:1px;
  text-transform:uppercase;
  color:var(--dim);
  flex-shrink:0;
  display:none;
}
@media(min-width:480px){.ep-name{display:block;}}
.ep-badge{font-family:'Space Mono',monospace;font-size:10px;padding:3px 8px;border:1px solid var(--border);text-transform:uppercase;color:#fff;background:#2d3436;}
.ep-badge.ready{background:#1e7e34;}
.ep-badge.maintenance{background:#f39c12;}
.ep-badge.closed{background:#7f1d1d;}

.ep-chevron{
  width:24px;height:24px;
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  transition:transform .2s;
}
.ep-header.open .ep-chevron{transform:rotate(180deg);border-color:var(--red);}
.ep-chevron svg{width:12px;height:12px;color:var(--muted);}

.ep-body{
  display:none;
  padding:0 14px 20px;
  background:var(--bg);
  border-top:1px solid var(--border);
}
.ep-body.open{display:block;animation:endpointOpen .28s cubic-bezier(.2,.8,.2,1) both;}
@keyframes endpointOpen{from{opacity:0;transform:translateY(-8px);clip-path:inset(0 0 100% 0)}to{opacity:1;transform:translateY(0);clip-path:inset(0 0 0 0)}}

.ep-desc{
  font-size:12px;
  color:var(--muted);
  margin:14px 0 16px;
  line-height:1.6;
}

.param-label{
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:2px;
  color:var(--dim);
  text-transform:uppercase;
  margin-bottom:8px;
}

.param-row{
  display:flex;
  gap:8px;
  margin-bottom:8px;
  flex-wrap:wrap;
}

.param-name{
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--red2);
  padding:6px 8px;
  background:rgba(192,57,43,0.08);
  border:1px solid rgba(192,57,43,0.2);
  white-space:nowrap;
}

.param-input{
  flex:1;
  min-width:0;
  background:var(--bg2);
  border:1px solid var(--border);
  padding:6px 10px;
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--text);
  outline:none;
  transition:border-color .15s;
}
.param-input:focus{border-color:var(--red);}

.ep-actions{
  display:flex;
  flex-direction:column;
  gap:10px;
  margin-top:18px;
}

.btn-execute{
  background:var(--red);
  color:#fff;
  border:none;
  padding:12px 18px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;
  font-weight:700;
  letter-spacing:1px;
  text-transform:uppercase;
  cursor:pointer;
  transition:background .15s;
  width:100%;
}
.btn-execute:hover{background:var(--red2);}
.btn-execute.loading{opacity:.6;cursor:not-allowed;}

.btn-clear,.btn-copy-result{
  background:var(--bg2);
  color:var(--muted);
  border:1px solid var(--border);
  padding:10px 14px;
  font-family:'Space Mono',monospace;
  font-size:11px;
  cursor:pointer;
  transition:background .15s,color .15s;
  white-space:nowrap;
}
.btn-clear:hover,.btn-copy-result:hover{background:var(--bg3);color:var(--text);}

.result-box{
  margin-top:0;
  background:var(--bg2);
  border:1px solid var(--border);
  border-top:none;
  border-left:3px solid var(--red);
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:#a8ff78;
  padding:18px 14px;
  white-space:pre-wrap;
  word-break:break-word;
  max-height:340px;
  overflow-y:auto;
  line-height:1.7;
  display:none;
}
.playground-controls{display:flex;gap:10px;flex-wrap:wrap;margin:10px 0 14px;}
.method-tabs{display:flex;gap:8px;flex-wrap:wrap;}
.result-tabs{display:none;align-items:center;gap:8px;flex-wrap:wrap;margin-top:18px;padding:12px 14px;border:1px solid var(--border);background:var(--bg2);}
.result-tabs.show{display:flex;}
.method-tab,.result-tab{border:1px solid var(--border);background:var(--bg3);color:var(--muted);padding:6px 10px;font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:1px;cursor:pointer;text-transform:uppercase;}
.method-tab.active{color:#fff;border-color:var(--red);background:var(--red);}
.method-tab[data-method="POST"].active{border-color:#1e7e34;background:#1e7e34;}
.result-tab.active{color:var(--red2);border-color:transparent;background:transparent;}
.result-spacer{flex:1;}
.btn-copy-result{width:40px;height:36px;padding:0;display:inline-flex;align-items:center;justify-content:center;}
.btn-copy-result svg{width:16px;height:16px;}
.result-status{display:inline-flex;align-items:center;gap:10px;font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:1px;color:var(--muted);}
.result-code.ok{color:#2ecc71;}.result-code.err{color:#ff7675;}.result-ms{color:var(--dim);font-weight:400;}

.result-box.show{display:block;}
.result-box.error{color:#ff7675;border-left-color:var(--red2);}

/* MENU OVERLAY */
.menu-overlay{position:fixed;inset:0;background:var(--bg);z-index:200;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);}
.menu-overlay.open{transform:translateX(0);}
.menu-top{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;border-bottom:1px solid var(--border);}
.menu-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;color:var(--muted);}
.menu-close{width:44px;height:44px;border:1px solid var(--border);background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--text);}
.menu-close:hover{background:var(--red);}
.menu-links{flex:1;display:flex;flex-direction:column;justify-content:center;padding:32px;gap:4px;}
.menu-link{font-family:'Barlow Condensed',sans-serif;font-size:clamp(48px,14vw,72px);font-weight:900;text-transform:uppercase;color:var(--dim);text-decoration:none;line-height:1;transition:color .15s;}
.menu-link:hover{color:var(--text);}
.menu-divider{height:1px;background:var(--border);margin:16px 0;}
.menu-secondary{display:flex;flex-direction:column;gap:4px;}
.menu-sec-link{font-family:'Barlow Condensed',sans-serif;font-size:clamp(24px,7vw,36px);font-weight:700;text-transform:uppercase;color:var(--dim);text-decoration:none;line-height:1.2;transition:color .15s;}
.menu-sec-link:hover{color:var(--text);}
.menu-bottom{padding:24px 32px;border-top:1px solid var(--border);}
.btn-join{display:block;width:100%;background:var(--red);color:#fff;text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;padding:18px;transition:background .2s;}
.btn-join:hover{background:var(--red2);}
</style>
</head>
<body>

<div class="pg-loader" id="pgLoader">
  <div class="pg-loader-inner">
    <div class="pg-loader-mark">
      <div class="pg-loader-ring"></div>
      <div class="pg-loader-sq"></div>
    </div>
    <div class="pg-loader-title" id="pgLoaderText">Menyiapkan Playground</div>
    <div class="pg-loader-sub">DAFTAR LAYANAN DIMUAT</div>
  </div>
</div>

<nav>
  <a href="/" class="nav-logo"><div class="logo-sq"></div>YOUZ API</a>
  <div style="display:flex;gap:8px;align-items:center;">
    <a href="<%= user ? '/perfil' : '/login' %>" class="badge-btn" style="text-decoration:none;"><%= user ? 'Akun' : 'Masuk' %></a>
    <button class="nav-menu-btn" onclick="openMenu()"><span></span><span></span></button>
  </div>
</nav>

<div class="page-hero">
  <h1>API <span class="red">CONSOLE</span><span class="version">V1</span></h1>
  <p class="page-hero-sub">DIRECT ENDPOINT EXECUTION ENVIRONMENT</p>
</div>

<div class="console-wrap">

  <div class="search-box">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input type="text" class="search-input" id="searchInput" placeholder="SEARCH ENDPOINT" oninput="filterEndpoints(this.value)">
  </div>



  <!-- PLUGIN GROUPS -->
  <div class="endpoint-group" data-group="search">
    <div class="group-header"><span class="group-title">SEARCH</span><span class="group-count">1 ENDPOINT</span></div>
    <div class="ep-list">
      <div class="ep-item" data-name="yt search youtube /api/s/youtube">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/s/youtube</span><span class="ep-name">YT SEARCH</span><span class="ep-badge" data-status-for="/api/s/youtube">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
        <div class="ep-body" data-path="/api/s/youtube" data-params="query"><p class="ep-desc">Cari video YouTube.</p><div class="playground-controls"><div class="method-tabs"><button class="method-tab active" type="button" data-method="GET">GET</button><button class="method-tab" type="button" data-method="POST">POST</button></div></div><div class="param-label">INPUT</div><div class="param-row"><span class="param-name">query</span><input type="text" class="param-input" placeholder="contoh: musik lofi" data-param="query"></div><div class="ep-actions"><button class="btn-execute" onclick="executeApi(this, '/api/s/youtube', ['query'])">EXECUTE</button><button class="btn-clear" onclick="clearEndpoint(this)" type="button">CLEAR</button></div><div class="result-tabs"><button class="result-tab active" type="button" data-tab="preview">PREVIEW</button><button class="result-tab" type="button" data-tab="headers">HEADERS</button><button class="result-tab" type="button" data-tab="curl">CURL</button><span class="result-spacer"></span><button class="btn-copy-result" onclick="copyResult(this)" type="button" aria-label="Salin hasil"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 7V5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 01-2 2h-2"/><rect x="4" y="7" width="12" height="14" rx="2"/></svg></button><span class="result-status"><span class="result-code">---</span><span class="result-ms">0ms</span></span></div><pre class="result-box"></pre></div>
      </div>
    </div>
  </div>

  <div class="endpoint-group" data-group="downloader">
    <div class="group-header"><span class="group-title">DOWNLOADER</span><span class="group-count">1 ENDPOINT</span></div>
    <div class="ep-list">
      <div class="ep-item" data-name="tiktok downloader /api/downloader/tiktok">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/downloader/tiktok</span><span class="ep-name">TIKTOK</span><span class="ep-badge" data-status-for="/api/downloader/tiktok">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
        <div class="ep-body" data-path="/api/downloader/tiktok" data-params="url"><p class="ep-desc">Download video TikTok via SnapTik.</p><div class="playground-controls"><div class="method-tabs"><button class="method-tab active" type="button" data-method="GET">GET</button><button class="method-tab" type="button" data-method="POST">POST</button></div></div><div class="param-label">INPUT</div><div class="param-row"><span class="param-name">url</span><input type="text" class="param-input" placeholder="https://vt.tiktok.com/..." data-param="url"></div><div class="ep-actions"><button class="btn-execute" onclick="executeApi(this, '/api/downloader/tiktok', ['url'])">EXECUTE</button><button class="btn-clear" onclick="clearEndpoint(this)" type="button">CLEAR</button></div><div class="result-tabs"><button class="result-tab active" type="button" data-tab="preview">PREVIEW</button><button class="result-tab" type="button" data-tab="headers">HEADERS</button><button class="result-tab" type="button" data-tab="curl">CURL</button><span class="result-spacer"></span><button class="btn-copy-result" onclick="copyResult(this)" type="button" aria-label="Salin hasil"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 7V5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 01-2 2h-2"/><rect x="4" y="7" width="12" height="14" rx="2"/></svg></button><span class="result-status"><span class="result-code">---</span><span class="result-ms">0ms</span></span></div><pre class="result-box"></pre></div>
      </div>
    </div>
  </div>

  <div class="endpoint-group" data-group="tools">
    <div class="group-header"><span class="group-title">TOOLS</span><span class="group-count">3 ENDPOINTS</span></div>
    <div class="ep-list">
      
      <div class="ep-item" data-name="text2qr /api/tools/text2qr">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/tools/text2qr</span><span class="ep-name">TEXT2QR</span><span class="ep-badge" data-status-for="/api/tools/text2qr">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
        <div class="ep-body" data-path="/api/tools/text2qr" data-params="text"><p class="ep-desc">Generate QR image from plain text.</p><div class="playground-controls"><div class="method-tabs"><button class="method-tab active" type="button" data-method="GET">GET</button><button class="method-tab" type="button" data-method="POST">POST</button></div></div><div class="param-label">INPUT</div><div class="param-row"><span class="param-name">text</span><input type="text" class="param-input" placeholder="contoh: halo dunia" data-param="text"></div><div class="ep-actions"><button class="btn-execute" onclick="executeApi(this, '/api/tools/text2qr', ['text'])">EXECUTE</button><button class="btn-clear" onclick="clearEndpoint(this)" type="button">CLEAR</button></div><div class="result-tabs"><button class="result-tab active" type="button" data-tab="preview">PREVIEW</button><button class="result-tab" type="button" data-tab="headers">HEADERS</button><button class="result-tab" type="button" data-tab="curl">CURL</button><span class="result-spacer"></span><button class="btn-copy-result" onclick="copyResult(this)" type="button" aria-label="Salin hasil"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 7V5a2 2 0 012-2h8a2 2 0 012 2v10a2 2 0 01-2 2h-2"/><rect x="4" y="7" width="12" height="14" rx="2"/></svg></button><span class="result-status"><span class="result-code">---</span><span class="result-ms">0ms</span></span></div><pre class="result-box"></pre></div>
      </div>
<div class="ep-item" data-name="qr2text /api/tools/qr2text">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/tools/qr2text</span><span class="ep-name">QR2TEXT</span><span class="ep-badge" data-status-for="/api/tools/qr2text">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
