<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>API Console V2 — API SIPUTZX</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --red:#c0392b;--red2:#e74c3c;
  --bg:#111111;--bg2:#181818;--bg3:#1e1e1e;
  --border:rgba(255,255,255,0.07);
  --text:#ffffff;--muted:#888888;--dim:#555555;
  --blue:#2980b9;--blue2:#3498db;
}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;min-height:100vh;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}

.pg-loader{position:fixed;inset:0;z-index:300;display:flex;align-items:center;justify-content:center;background:rgba(17,17,17,0.98);backdrop-filter:blur(10px);transition:opacity .35s ease,visibility .35s ease;}
.pg-loader.hide{opacity:0;visibility:hidden;}
.pg-loader-inner{width:min(520px,92vw);padding:28px 18px;border:1px solid var(--border);background:rgba(24,24,24,0.7);text-align:center;}
.pg-loader-mark{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:14px;}
.pg-loader-ring{width:26px;height:26px;border-radius:999px;border:2px solid rgba(255,255,255,0.12);border-top-color:var(--red);animation:pgspin .85s linear infinite;}
.pg-loader-sq{width:16px;height:16px;background:var(--red);animation:pgpulse .9s ease-in-out infinite;}
.pg-loader-title{font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:900;letter-spacing:1px;text-transform:uppercase;margin-bottom:6px;}
.pg-loader-sub{font-family:'Space Mono',monospace;font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--dim);}
@keyframes pgspin{to{transform:rotate(360deg)}}
@keyframes pgpulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.72);opacity:.65}}

.settings-box{display:flex;flex-direction:column;gap:10px;border:1px solid var(--border);background:var(--bg2);padding:14px 16px;margin-bottom:14px;}
.settings-row{display:flex;gap:10px;flex-wrap:wrap;align-items:end;}
.settings-field{flex:1;min-width:180px;}
.key-row{display:flex;gap:8px;align-items:center;}
.key-blur{filter:blur(6px);user-select:none;}
.badge-btn{border:1px solid var(--border);background:var(--bg3);color:var(--text);padding:8px 10px;font-size:10px;font-weight:700;letter-spacing:1px;cursor:pointer;text-transform:uppercase;}
.settings-label{font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:2px;color:var(--dim);text-transform:uppercase;margin-bottom:8px;}
.settings-input{width:100%;background:var(--bg);border:1px solid var(--border);padding:12px 12px;font-family:'Space Mono',monospace;font-size:11px;color:var(--text);outline:none;}
.settings-input::placeholder{color:var(--dim);}
.settings-color{height:41px;padding:0;border-radius:0;}

nav{position:sticky;top:0;z-index:100;background:rgba(17,17,17,0.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;}
.nav-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;text-decoration:none;color:var(--text);}
.logo-sq{width:20px;height:20px;background:var(--red);flex-shrink:0;}
.nav-menu-btn{width:44px;height:44px;border:1px solid var(--border);background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:5px;}
.nav-menu-btn span{display:block;width:20px;height:2px;background:var(--text);}

.page-hero{
  position:relative;z-index:1;
  text-align:center;
  padding:60px 24px 48px;
  border-bottom:1px solid var(--border);
}
.page-hero h1{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(40px,12vw,72px);
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:1px;
  margin-bottom:10px;
}
.page-hero h1 .red{color:var(--red);}
.page-hero h1 .version{
  font-size:clamp(18px,5vw,28px);
  color:var(--dim);
  vertical-align:middle;
  margin-left:8px;
}
.page-hero-sub{
  font-size:12px;
  font-weight:600;
  letter-spacing:3px;
  text-transform:uppercase;
  color:var(--dim);
}

.console-wrap{
  position:relative;z-index:1;
  padding:24px 16px 80px;
  max-width:700px;
  margin:0 auto;
}

.search-box{
  position:sticky;
  top:64px;
  z-index:80;
  display:flex;
  align-items:center;
  gap:12px;
  border:1px solid var(--border);
  background:var(--bg2);
  padding:14px 16px;
  margin-bottom:32px;
}
.search-box svg{width:18px;height:18px;color:var(--dim);flex-shrink:0;}
.search-input{
  flex:1;
  background:none;
  border:none;
  outline:none;
  font-family:'Space Mono',monospace;
  font-size:12px;
  font-weight:700;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--muted);
}
.search-input::placeholder{color:var(--dim);}

.endpoint-group{
  margin-bottom:32px;
}

.group-header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:12px;
  padding-bottom:8px;
  border-left:3px solid var(--red);
  padding-left:12px;
}
.group-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:20px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.5px;
}
.group-count{
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:1px;
  color:var(--dim);
}

.ep-list{
  display:flex;
  flex-direction:column;
  gap:-1px;
  background:var(--border);
}

.ep-item{
  background:var(--bg);
  border:none;
}

.ep-header{
  display:flex;
  align-items:center;
  gap:12px;
  padding:14px 14px;
  cursor:pointer;
  transition:background .15s;
  user-select:none;
}
.ep-header:hover{background:var(--bg2);}
.ep-header.open{background:var(--bg3);}

.ep-method{
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;
  font-weight:800;
  letter-spacing:1px;
  padding:3px 8px;
  background:var(--blue);
  color:#fff;
  flex-shrink:0;
  min-width:44px;
  text-align:center;
}
.ep-path{
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--muted);
  flex:1;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
}
.ep-name{
  font-size:11px;
  font-weight:600;
  letter-spacing:1px;
  text-transform:uppercase;
  color:var(--dim);
  flex-shrink:0;
  display:none;
}
@media(min-width:480px){.ep-name{display:block;}}
.ep-badge{font-family:'Space Mono',monospace;font-size:10px;padding:3px 8px;border:1px solid var(--border);text-transform:uppercase;color:#fff;background:#2d3436;}
.ep-badge.ready{background:#1e7e34;}
.ep-badge.maintenance{background:#f39c12;}
.ep-badge.closed{background:#7f1d1d;}

.ep-chevron{
  width:24px;height:24px;
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  transition:transform .2s;
}
.ep-header.open .ep-chevron{transform:rotate(180deg);border-color:var(--red);}
.ep-chevron svg{width:12px;height:12px;color:var(--muted);}

.ep-body{
  display:none;
  padding:0 14px 20px;
  background:var(--bg);
  border-top:1px solid var(--border);
}
.ep-body.open{display:block;}

.ep-desc{
  font-size:13px;
  color:var(--muted);
  margin:14px 0 16px;
  line-height:1.6;
}

.param-label{
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:2px;
  color:var(--dim);
  text-transform:uppercase;
  margin-bottom:8px;
}

.param-row{
  display:flex;
  gap:8px;
  margin-bottom:8px;
  flex-wrap:wrap;
}

.param-name{
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--red2);
  padding:6px 8px;
  background:rgba(192,57,43,0.08);
  border:1px solid rgba(192,57,43,0.2);
  white-space:nowrap;
}

.param-input{
  flex:1;
  min-width:0;
  background:var(--bg2);
  border:1px solid var(--border);
  padding:6px 10px;
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--text);
  outline:none;
  transition:border-color .15s;
}
.param-input:focus{border-color:var(--red);}

.ep-actions{
  display:flex;
  gap:8px;
  margin-top:12px;
}

.btn-execute{
  background:var(--red);
  color:#fff;
  border:none;
  padding:10px 20px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:14px;
  font-weight:700;
  letter-spacing:1px;
  text-transform:uppercase;
  cursor:pointer;
  transition:background .15s;
  flex:1;
}
.btn-execute:hover{background:var(--red2);}
.btn-execute.loading{opacity:.6;cursor:not-allowed;}

.btn-copy-url{
  background:var(--bg2);
  color:var(--muted);
  border:1px solid var(--border);
  padding:10px 14px;
  font-family:'Space Mono',monospace;
  font-size:11px;
  cursor:pointer;
  transition:background .15s,color .15s;
  white-space:nowrap;
}
.btn-copy-url:hover{background:var(--bg3);color:var(--text);}

.result-box{
  margin-top:14px;
  background:var(--bg2);
  border:1px solid var(--border);
  border-left:3px solid var(--red);
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:#a8ff78;
  padding:14px;
  white-space:pre-wrap;
  word-break:break-all;
  max-height:300px;
  overflow-y:auto;
  line-height:1.7;
  display:none;
}
.result-box.show{display:block;}
.result-box.error{color:#ff7675;border-left-color:var(--red2);}

/* MENU OVERLAY */
.menu-overlay{position:fixed;inset:0;background:var(--bg);z-index:200;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);}
.menu-overlay.open{transform:translateX(0);}
.menu-top{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:56px;border-bottom:1px solid var(--border);}
.menu-logo{display:flex;align-items:center;gap:10px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;color:var(--muted);}
.menu-close{width:44px;height:44px;border:1px solid var(--border);background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;color:var(--text);}
.menu-close:hover{background:var(--red);}
.menu-links{flex:1;display:flex;flex-direction:column;justify-content:center;padding:32px;gap:4px;}
.menu-link{font-family:'Barlow Condensed',sans-serif;font-size:clamp(48px,14vw,72px);font-weight:900;text-transform:uppercase;color:var(--dim);text-decoration:none;line-height:1;transition:color .15s;}
.menu-link:hover{color:var(--text);}
.menu-divider{height:1px;background:var(--border);margin:16px 0;}
.menu-secondary{display:flex;flex-direction:column;gap:4px;}
.menu-sec-link{font-family:'Barlow Condensed',sans-serif;font-size:clamp(24px,7vw,36px);font-weight:700;text-transform:uppercase;color:var(--dim);text-decoration:none;line-height:1.2;transition:color .15s;}
.menu-sec-link:hover{color:var(--text);}
.menu-bottom{padding:24px 32px;border-top:1px solid var(--border);}
.btn-join{display:block;width:100%;background:var(--red);color:#fff;text-align:center;font-family:'Barlow Condensed',sans-serif;font-size:16px;font-weight:700;letter-spacing:2px;text-transform:uppercase;text-decoration:none;padding:18px;transition:background .2s;}
.btn-join:hover{background:var(--red2);}
</style>
</head>
<body>

<div class="pg-loader" id="pgLoader">
  <div class="pg-loader-inner">
    <div class="pg-loader-mark">
      <div class="pg-loader-ring"></div>
      <div class="pg-loader-sq"></div>
    </div>
    <div class="pg-loader-title" id="pgLoaderText">Loading Playground</div>
    <div class="pg-loader-sub">PREPARING CONSOLE</div>
  </div>
</div>

<nav>
  <a href="/" class="nav-logo"><div class="logo-sq"></div>API SIPUTZX</a>
  <div style="display:flex;gap:8px;align-items:center;">
    <a href="<%= user ? '/perfil' : '/login' %>" class="badge-btn" style="text-decoration:none;"><%= user ? 'Profile' : 'Login' %></a>
    <button class="nav-menu-btn" onclick="openMenu()"><span></span><span></span></button>
  </div>
</nav>

<div class="page-hero">
  <h1>API <span class="red">CONSOLE</span><span class="version">V2</span></h1>
  <p class="page-hero-sub">DIRECT ENDPOINT EXECUTION ENVIRONMENT</p>
</div>

<div class="console-wrap">

  <div class="settings-box">
    <div class="settings-row">
      <div class="settings-field">
        <div class="settings-label">API TOKEN ACCOUNT</div>
        <div class='key-row'><input id="apiToken" class="settings-input key-blur" type="text" value="<%= user?.key || '' %>" readonly><button class="badge-btn" id="toggleKeyBtn" type="button">Look API Key</button><button class="badge-btn" id="copyKeyBtn" type="button" style="display:none;">Salin</button></div>
      </div>
    </div>
  </div>

  <div class="search-box">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    <input type="text" class="search-input" id="searchInput" placeholder="FILTER ENDPOINTS..." oninput="filterEndpoints(this.value)">
  </div>



  <!-- PLUGIN GROUPS -->
  <div class="endpoint-group" data-group="search">
    <div class="group-header"><span class="group-title">SEARCH</span><span class="group-count">1 ENDPOINT</span></div>
    <div class="ep-list">
      <div class="ep-item" data-name="yt search youtube /api/s/youtube">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/s/youtube</span><span class="ep-name">YT SEARCH</span><span class="ep-badge" data-status-for="/api/s/youtube">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
        <div class="ep-body"><p class="ep-desc">Cari video YouTube.</p><div class="param-label">PARAMETERS</div><div class="param-row"><span class="param-name">query</span><input type="text" class="param-input" placeholder="contoh: musik lofi" data-param="query"></div><div class="ep-actions"><button class="btn-execute" onclick="executeApi(this, '/api/s/youtube', ['query'])">▶ EXECUTE</button><button class="btn-copy-url" onclick="copyUrl(this, '/api/s/youtube', ['query'])">COPY URL</button></div><pre class="result-box"></pre></div>
      </div>
    </div>
  </div>

  <div class="endpoint-group" data-group="tools">
    <div class="group-header"><span class="group-title">TOOLS</span><span class="group-count">1 ENDPOINT</span></div>
    <div class="ep-list">
      <div class="ep-item" data-name="qr2text /api/tools/qr2text">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/tools/qr2text</span><span class="ep-name">QR2TEXT</span><span class="ep-badge" data-status-for="/api/tools/qr2text">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
        <div class="ep-body"><p class="ep-desc">Baca teks dari gambar QR (URL).</p><div class="param-label">PARAMETERS</div><div class="param-row"><span class="param-name">url</span><input type="text" class="param-input" placeholder="https://..." data-param="url"></div><div class="ep-actions"><button class="btn-execute" onclick="executeApi(this, '/api/tools/qr2text', ['url'])">▶ EXECUTE</button><button class="btn-copy-url" onclick="copyUrl(this, '/api/tools/qr2text', ['url'])">COPY URL</button></div><pre class="result-box"></pre></div>
      </div>
    </div>
  </div>

  <div class="endpoint-group" data-group="server">
    <div class="group-header"><span class="group-title">SERVER</span><span class="group-count">1 ENDPOINT</span></div>
    <div class="ep-list">
      <div class="ep-item" data-name="status /api/server/status">
        <div class="ep-header" onclick="toggleEp(this)"><span class="ep-method">GET</span><span class="ep-path">/api/server/status</span><span class="ep-name">STATUS</span><span class="ep-badge" data-status-for="/api/server/status">READY</span><div class="ep-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7"/></svg></div></div>
        <div class="ep-body"><p class="ep-desc">Status server YOUZ API.</p><div class="ep-actions"><button class="btn-execute" onclick="executeApi(this, '/api/server/status', [])">▶ EXECUTE</button><button class="btn-copy-url" onclick="copyUrl(this, '/api/server/status', [])">COPY URL</button></div><pre class="result-box"></pre></div>
      </div>
    </div>
  </div>

</div>

<!-- MENU OVERLAY -->
<div class="menu-overlay" id="menuOverlay">
  <div class="menu-top">
    <div class="menu-logo"><div class="logo-sq"></div>MENU</div>
    <button class="menu-close" onclick="closeMenu()">✕</button>
  </div>
  <div class="menu-links">
    <a href="/" class="menu-link">HOME</a>
    <a href="/playground" class="menu-link" style="color:var(--text);">PLAYGROUND</a>
    <a href="/monitor" class="menu-link">MONITOR</a>
    <div class="menu-divider"></div>
    <div class="menu-secondary">
      <a href="#" class="menu-sec-link">TERMS</a>
      <a href="#" class="menu-sec-link">PRIVACY</a>
    </div>
  </div>
  <div class="menu-bottom">
    <a href="#" class="btn-join">JOIN COMMUNITY</a>
  </div>
</div>

<script>
const BASE = '';

function openMenu(){document.getElementById('menuOverlay').classList.add('open');}
function closeMenu(){document.getElementById('menuOverlay').classList.remove('open');}
function getApiToken(){
  return (document.getElementById('apiToken')?.value || '').trim();
}

async function syncApiKeyFromAccount(){
  try{
    const res=await fetch('/api/account/me');
    const data=await res.json();
    if(data?.success && data?.data?.key){
      const tokenEl=document.getElementById('apiToken');
      if(tokenEl) tokenEl.value=data.data.key;
    }
  }catch(e){}
}


function initApiKeyVisibility(){
  const tokenEl=document.getElementById('apiToken');
  const toggleBtn=document.getElementById('toggleKeyBtn');
  const copyBtn=document.getElementById('copyKeyBtn');
  if(!tokenEl||!toggleBtn||!copyBtn) return;
  let visible=false;
  toggleBtn.addEventListener('click',()=>{
    visible=!visible;
    tokenEl.classList.toggle('key-blur',!visible);
    toggleBtn.textContent=visible?'Hide API Key':'Look API Key';
    copyBtn.style.display=visible?'inline-block':'none';
  });
  copyBtn.addEventListener('click', async ()=>{
    await navigator.clipboard.writeText(tokenEl.value||'');
    copyBtn.textContent='Copied!';
    setTimeout(()=>copyBtn.textContent='Salin',1200);
  });
}

function applyEndpointStatuses(endpoints){
  const m=new Map((endpoints||[]).map(e=>[e.rota,(e.status||'ready').toLowerCase()]));
  document.querySelectorAll('.ep-badge[data-status-for]').forEach((el)=>{
    const st=m.get(el.getAttribute('data-status-for'))||'ready';
    el.className=`ep-badge ${st}`;
    el.textContent=st.toUpperCase();
  });
}

function toggleEp(el){
  const body = el.nextElementSibling;
  const wasOpen = el.classList.contains('open');
  document.querySelectorAll('.ep-header.open').forEach(h=>{h.classList.remove('open');h.nextElementSibling.classList.remove('open');});
  if(!wasOpen){el.classList.add('open');body.classList.add('open');}
}

function getParams(btn, paramNames){
  const body = btn.closest('.ep-body');
  const params = {};
  paramNames.forEach(name=>{
    const inp = body.querySelector(`[data-param="${name}"]`);
    if(inp && inp.value.trim()) params[name] = inp.value.trim();
  });
  return params;
}

function buildUrl(path, params){
  const qs = Object.entries(params || {}).map(([k,v])=>`${k}=${encodeURIComponent(v)}`).join('&');
  return `${BASE}${path}${qs ? '?'+qs : ''}`;
}

function getResultBox(btn){
  const body = btn.closest('.ep-body');
  return body.querySelector('.result-box');
}

async function executeApi(btn, path, paramNames){
  const params = getParams(btn, paramNames);
  const url = buildUrl(path, params);
  const resultBox = getResultBox(btn);

  btn.classList.add('loading');
  btn.textContent = '⏳ LOADING...';
  resultBox.className = 'result-box show';
  resultBox.textContent = '// Fetching...';

  try{
    const token = getApiToken();
    const headers = token ? { Authorization: `Bearer ${token}` } : {};
    const res = await fetch(url, { headers });
    const data = await res.json();
    resultBox.textContent = JSON.stringify(data, null, 2);
    resultBox.className = 'result-box show';
  }catch(e){
    resultBox.textContent = `// Error: ${e.message}\n// URL: ${url}`;
    resultBox.className = 'result-box show error';
  }

  btn.classList.remove('loading');
  btn.textContent = '▶ EXECUTE';
}

function copyUrl(btn, path, paramNames){
  const params = getParams(btn, paramNames);
  const url = buildUrl(path, params);
  navigator.clipboard.writeText(url).then(()=>{
    const orig = btn.textContent;
    btn.textContent = 'COPIED!';
    btn.style.color = '#2ecc71';
    setTimeout(()=>{btn.textContent = orig;btn.style.color='';}, 1500);
  });
}

async function sinkronEndpointPlugin(){
  try{
    const res = await fetch('/api/plugins/list');
    const data = await res.json();
    const endpoints = data.data?.endpoints || [];
    const available = new Set(endpoints.map(e => e.rota));
    applyEndpointStatuses(endpoints);
    document.querySelectorAll('.ep-item').forEach((item)=>{
      const path = item.querySelector('.ep-path')?.textContent?.trim();
      if (!path) return;
      const btn = item.querySelector('.btn-execute');
      if (!available.has(path)) { item.style.opacity='0.45'; if(btn){btn.disabled=true; btn.textContent='TIDAK TERSEDIA';}}
    });
  }catch(e){}
}

function initLoader(){
  const loader = document.getElementById('pgLoader');
  if (!loader) return;
  window.addEventListener('load', () => {
    loader.classList.add('hide');
    setTimeout(() => loader.remove(), 600);
  });
}

syncApiKeyFromAccount();
initApiKeyVisibility();
initLoader();
sinkronEndpointPlugin();

function filterEndpoints(val){
  const q = val.toLowerCase();
  document.querySelectorAll('.ep-item').forEach(item=>{
    const text = item.getAttribute('data-name') || '';
    const path = item.querySelector('.ep-path')?.textContent || '';
    const match = (text + path).toLowerCase().includes(q);
    item.style.display = match ? '' : 'none';
  });
  document.querySelectorAll('.endpoint-group').forEach(grp=>{
    const visible = [...grp.querySelectorAll('.ep-item')].some(i=>i.style.display!=='none');
    grp.style.display = visible ? '' : 'none';
  });
}
</script>
</body>
