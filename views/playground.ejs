<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Playground — YOUZ API</title>
<style>
body{font-family:Arial,sans-serif;background:#111;color:#fff;margin:0} .wrap{max-width:900px;margin:0 auto;padding:20px}
.card{border:1px solid #333;background:#1a1a1a;margin:12px 0;padding:14px} input{width:100%;padding:10px;background:#222;border:1px solid #444;color:#fff}
button{margin-top:8px;padding:10px 14px;background:#c0392b;color:#fff;border:0;cursor:pointer} pre{background:#0f0f0f;padding:10px;white-space:pre-wrap}
a{color:#fff}
</style>
</head>
<body>
<div class="wrap">
  <h1>YOUZ API Playground</h1>
  <p><a href="/">Home</a> · <a href="/monitor">Monitor</a></p>

  <h2>SEARCH</h2>
  <div class="card" data-path="/api/s/youtube">
    <b>YT SEARCH</b><br><small>/api/s/youtube</small>
    <input data-param="query" placeholder="contoh: musik lofi" />
    <button onclick="eksekusiApi(this, '/api/s/youtube', ['query'])">EXECUTE</button>
    <pre></pre>
  </div>

  <h2>TOOLS</h2>
  <div class="card" data-path="/api/tools/qr2text">
    <b>qr2text</b><br><small>/api/tools/qr2text</small>
    <input data-param="url" placeholder="URL gambar QR" />
    <button onclick="eksekusiApi(this, '/api/tools/qr2text', ['url'])">EXECUTE</button>
    <pre></pre>
  </div>

  <h2>SERVER</h2>
  <div class="card" data-path="/api/server/status">
    <b>status</b><br><small>/api/server/status</small>
    <button onclick="eksekusiApi(this, '/api/server/status', [])">EXECUTE</button>
    <pre></pre>
  </div>
</div>
<script>
function params(el,names){const o={}; names.forEach(n=>{const i=el.parentElement.querySelector(`[data-param="${n}"]`); if(i&&i.value.trim())o[n]=i.value.trim()}); return o}
function qs(o){const q=new URLSearchParams(o).toString(); return q?`?${q}`:''}
async function eksekusiApi(btn,path,names){
  const box=btn.parentElement.querySelector('pre');
  const url=path+qs(params(btn,names));
  box.textContent='Loading...';
  try{const r=await fetch(url); const d=await r.json(); box.textContent=JSON.stringify(d,null,2)}catch(e){box.textContent=e.message}
}

async function sinkronPlugin(){
  try{
    const r=await fetch('/api/plugins/list');
    const d=await r.json();
    const set=new Set((d.endpoints||[]).map(x=>x.rota));
    document.querySelectorAll('.card[data-path]').forEach(c=>{
      const p=c.dataset.path; if(!set.has(p)){ c.style.opacity='.45'; c.querySelector('button').disabled=true; c.querySelector('button').textContent='TIDAK TERSEDIA'; }
    });
  }catch{}
}
sinkronPlugin();
</script>
</body>
</html>
