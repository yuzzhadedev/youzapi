<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>API SIPUTZX — No Login. No Key. Just Pure API.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Barlow:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --red:#c0392b;
  --red2:#e74c3c;
  --bg:#111111;
  --bg2:#181818;
  --bg3:#1e1e1e;
  --border:rgba(255,255,255,0.07);
  --text:#ffffff;
  --muted:#888888;
  --dim:#555555;
}

html{scroll-behavior:smooth}

body{
  font-family:'Barlow',sans-serif;
  background:var(--bg);
  color:var(--text);
  overflow-x:hidden;
}

/* GRID BG */
body::before{
  content:'';
  position:fixed;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,0.025) 1px,transparent 1px);
  background-size:60px 60px;
  pointer-events:none;
  z-index:0;
}

/* NAV */
nav{
  position:sticky;
  top:0;
  z-index:100;
  background:rgba(17,17,17,0.95);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 20px;
  height:56px;
}

.nav-logo{
  display:flex;
  align-items:center;
  gap:10px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;
  font-weight:700;
  letter-spacing:1px;
  text-decoration:none;
  color:var(--text);
}

.logo-sq{
  width:20px;
  height:20px;
  background:var(--red);
  flex-shrink:0;
}

.nav-menu-btn{
  width:44px;height:44px;
  border:1px solid var(--border);
  background:var(--bg2);
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  flex-direction:column;gap:5px;
  transition:background .2s;
}
.nav-menu-btn:hover{background:var(--bg3);}
.nav-menu-btn span{display:block;width:20px;height:2px;background:var(--text);}

/* HERO */
.hero{
  position:relative;
  z-index:1;
  padding:80px 24px 60px;
  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;
}

.status-pill{
  display:inline-flex;
  align-items:center;
  gap:8px;
  border:1px solid var(--border);
  background:var(--bg2);
  padding:6px 14px;
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:2px;
  color:var(--muted);
  margin-bottom:40px;
}
.status-dot{width:8px;height:8px;background:#2ecc71;border-radius:50%;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

.hero-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(64px,18vw,110px);
  font-weight:900;
  line-height:.9;
  letter-spacing:-1px;
  text-transform:uppercase;
  margin-bottom:32px;
  animation:fadeUp .7s ease both;
}

.hero-title .accent{color:var(--red);}

@keyframes fadeUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}

.hero-desc{
  font-size:16px;
  color:var(--muted);
  line-height:1.6;
  max-width:380px;
  margin-bottom:48px;
  animation:fadeUp .8s .1s ease both;
}
.hero-desc strong{color:var(--text);}

.btn-cta{
  display:inline-block;
  background:var(--red);
  color:#fff;
  font-family:'Barlow Condensed',sans-serif;
  font-size:16px;
  font-weight:700;
  letter-spacing:2px;
  text-transform:uppercase;
  text-decoration:none;
  padding:18px 48px;
  border:none;
  cursor:pointer;
  transition:background .2s,transform .15s;
  animation:fadeUp .9s .2s ease both;
}
.btn-cta:hover{background:var(--red2);transform:translateY(-2px);}
.btn-cta:active{transform:translateY(0);}

/* STATS GRID */
.stats{
  position:relative;z-index:1;
  display:grid;
  grid-template-columns:1fr 1fr;
  border-top:1px solid var(--border);
}

.stat-box{
  padding:40px 24px;
  border-right:1px solid var(--border);
  border-bottom:1px solid var(--border);
  text-align:center;
}
.stat-box:nth-child(even){border-right:none;}

.stat-val{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(36px,10vw,60px);
  font-weight:900;
  line-height:1;
  margin-bottom:6px;
}
.stat-label{
  font-size:11px;
  font-weight:600;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--dim);
}

/* SECTION WHY */
.section{
  position:relative;z-index:1;
  padding:80px 24px;
  border-top:1px solid var(--border);
}

.section-bar{
  width:48px;height:3px;
  background:var(--red);
  margin-bottom:24px;
}

.section-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(40px,10vw,64px);
  font-weight:900;
  line-height:.95;
  text-transform:uppercase;
  margin-bottom:24px;
}

.section-desc{
  font-size:15px;
  color:var(--muted);
  line-height:1.7;
  margin-bottom:12px;
  max-width:460px;
}

/* FEATURE CARDS */
.feat-cards{
  display:flex;
  flex-direction:column;
  gap:1px;
  background:var(--border);
  margin-top:48px;
}

.feat-card{
  background:var(--bg);
  padding:28px 24px;
  border:none;
}

.feat-icon{
  font-size:28px;
  color:var(--red);
  margin-bottom:16px;
  display:block;
}

.feat-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:22px;
  font-weight:800;
  letter-spacing:.5px;
  text-transform:uppercase;
  margin-bottom:16px;
  border-bottom:1px solid var(--border);
  padding-bottom:14px;
}

.feat-list{
  list-style:none;
  display:flex;
  flex-direction:column;
  gap:8px;
}
.feat-list li{
  display:flex;
  align-items:center;
  gap:10px;
  font-size:13px;
  font-weight:600;
  letter-spacing:1.5px;
  text-transform:uppercase;
  color:var(--muted);
}
.feat-list li::before{
  content:'';
  width:6px;height:6px;
  background:var(--red);
  flex-shrink:0;
}

/* ENDPOINT CATALOG */
.catalog-section{
  position:relative;z-index:1;
  padding:80px 0 40px;
  border-top:1px solid var(--border);
}

.catalog-heading{
  text-align:center;
  padding:0 24px;
  margin-bottom:40px;
}
.catalog-heading h2{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(36px,10vw,56px);
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:1px;
}
.catalog-heading h2 span{
  background:var(--red);
  color:#fff;
  padding:0 10px;
}

.cat-scroll{
  display:flex;
  gap:1px;
  background:var(--border);
  overflow-x:auto;
  scrollbar-width:none;
}
.cat-scroll::-webkit-scrollbar{display:none;}

.cat-card{
  flex:0 0 220px;
  background:var(--bg2);
  padding:28px 24px;
  border:none;
  cursor:pointer;
  transition:background .15s;
  text-decoration:none;
  color:var(--text);
  display:flex;
  flex-direction:column;
  gap:12px;
}
.cat-card:hover{background:var(--bg3);}

.cat-icon-wrap{
  width:44px;height:44px;
  border:1px solid var(--border);
  background:var(--bg);
  display:flex;align-items:center;justify-content:center;
  font-family:'Barlow Condensed',sans-serif;
  font-size:13px;
  font-weight:800;
  letter-spacing:1px;
}
.cat-icon-wrap svg{width:22px;height:22px;color:var(--muted);}

.cat-title{
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:.5px;
}
.cat-sub{
  font-size:12px;
  color:var(--muted);
  line-height:1.5;
}

/* Q&A */
.qa-section{
  position:relative;z-index:1;
  padding:80px 24px;
  border-top:1px solid var(--border);
}

.qa-heading{
  text-align:center;
  margin-bottom:48px;
}
.qa-heading h2{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(48px,14vw,80px);
  font-weight:900;
}
.qa-heading h2 .amp{color:var(--red);}

.qa-item{
  border:1px solid var(--border);
  margin-bottom:-1px;
}

.qa-q{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:20px 20px;
  cursor:pointer;
  background:var(--bg);
  transition:background .15s;
  user-select:none;
}
.qa-q:hover{background:var(--bg2);}
.qa-q.open{background:rgba(192,57,43,0.08);border-left:3px solid var(--red);}

.qa-q-text{
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;
  font-weight:700;
  letter-spacing:.5px;
  text-transform:uppercase;
}
.qa-chevron{
  width:28px;height:28px;
  border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  transition:transform .2s;
}
.qa-q.open .qa-chevron{transform:rotate(180deg);border-color:var(--red);}
.qa-chevron svg{width:14px;height:14px;color:var(--muted);}

.qa-a{
  display:none;
  padding:0 20px 20px;
  font-size:14px;
  color:var(--muted);
  line-height:1.7;
  background:var(--bg);
}
.qa-a.open{display:block;}

/* SPONSORS */
.sponsors{
  position:relative;z-index:1;
  padding:60px 24px;
  border-top:1px solid var(--border);
}

.sponsors-label{
  text-align:center;
  font-size:11px;
  letter-spacing:3px;
  color:var(--dim);
  font-weight:600;
  margin-bottom:32px;
  display:flex;
  align-items:center;
  gap:16px;
}
.sponsors-label::before,.sponsors-label::after{content:'';flex:1;height:1px;background:var(--border);}

.sponsors-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:1px;
  background:var(--border);
}
.sponsor-box{
  background:var(--bg2);
  padding:32px 24px;
  display:flex;
  align-items:center;
  justify-content:center;
  min-height:100px;
}
.sponsor-name{
  font-family:'Barlow Condensed',sans-serif;
  font-size:20px;
  font-weight:800;
  text-transform:uppercase;
  letter-spacing:1px;
  color:var(--muted);
  text-align:center;
  line-height:1.3;
}

/* FOOTER */
footer{
  position:relative;z-index:1;
  border-top:1px solid var(--border);
  padding:48px 24px 32px;
}

.footer-brand{
  font-family:'Barlow Condensed',sans-serif;
  font-size:28px;
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:1px;
  margin-bottom:8px;
}
.footer-status{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-family:'Space Mono',monospace;
  font-size:10px;
  font-weight:700;
  letter-spacing:1px;
  color:#2ecc71;
  margin-bottom:16px;
}
.footer-tagline{
  font-size:14px;
  color:var(--muted);
  line-height:1.6;
  margin-bottom:32px;
  max-width:300px;
}

.social-row{
  display:flex;
  gap:1px;
  flex-wrap:wrap;
  margin-bottom:40px;
}
.social-btn{
  width:48px;height:48px;
  border:1px solid var(--border);
  background:var(--bg2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;
  transition:background .2s,border-color .2s;
  text-decoration:none;
  color:var(--muted);
}
.social-btn:hover{background:var(--bg3);border-color:var(--red);color:var(--text);}
.social-btn svg{width:18px;height:18px;}

.footer-cols{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:32px;
  margin-bottom:40px;
}
.footer-col-title{
  font-size:10px;
  font-weight:700;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--dim);
  margin-bottom:16px;
}
.footer-col a{
  display:block;
  font-size:14px;
  color:var(--muted);
  text-decoration:none;
  margin-bottom:10px;
  transition:color .15s;
}
.footer-col a:hover{color:var(--text);}
.footer-col a.has-dot{display:flex;align-items:center;gap:8px;}
.footer-col a.has-dot::after{content:'■';font-size:8px;color:#2ecc71;}

.footer-bottom{
  border-top:1px solid var(--border);
  padding-top:24px;
  display:flex;
  flex-wrap:wrap;
  gap:12px;
  align-items:center;
  justify-content:space-between;
}
.footer-copy{
  font-family:'Space Mono',monospace;
  font-size:11px;
  color:var(--dim);
}
.footer-links{
  display:flex;
  gap:16px;
}
.footer-links a{
  font-size:12px;
  color:var(--dim);
  text-decoration:none;
  transition:color .15s;
}
.footer-links a:hover{color:var(--text);}

/* MOBILE MENU OVERLAY */
.menu-overlay{
  position:fixed;
  inset:0;
  background:var(--bg);
  z-index:200;
  display:flex;
  flex-direction:column;
  transform:translateX(100%);
  transition:transform .3s cubic-bezier(.4,0,.2,1);
}
.menu-overlay.open{transform:translateX(0);}

.menu-top{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 20px;
  height:56px;
  border-bottom:1px solid var(--border);
}
.menu-logo{
  display:flex;align-items:center;gap:10px;
  font-family:'Barlow Condensed',sans-serif;
  font-size:18px;font-weight:700;letter-spacing:1px;color:var(--muted);
}
.menu-close{
  width:44px;height:44px;
  border:1px solid var(--border);
  background:var(--bg2);
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;
  color:var(--text);
  transition:background .2s;
}
.menu-close:hover{background:var(--red);}

.menu-links{
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:center;
  padding:32px 32px;
  gap:4px;
}

.menu-link{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(48px,14vw,72px);
  font-weight:900;
  text-transform:uppercase;
  color:var(--dim);
  text-decoration:none;
  line-height:1;
  transition:color .15s;
  display:block;
}
.menu-link:hover{color:var(--text);}

.menu-divider{height:1px;background:var(--border);margin:16px 0;}

.menu-secondary{display:flex;flex-direction:column;gap:4px;}
.menu-sec-link{
  font-family:'Barlow Condensed',sans-serif;
  font-size:clamp(24px,7vw,36px);
  font-weight:700;
  text-transform:uppercase;
  color:var(--dim);
  text-decoration:none;
  line-height:1.2;
  transition:color .15s;
}
.menu-sec-link:hover{color:var(--text);}

.menu-bottom{
  padding:24px 32px;
  border-top:1px solid var(--border);
}
.btn-join{
  display:block;
  width:100%;
  background:var(--red);
  color:#fff;
  text-align:center;
  font-family:'Barlow Condensed',sans-serif;
  font-size:16px;
  font-weight:700;
  letter-spacing:2px;
  text-transform:uppercase;
  text-decoration:none;
  padding:18px;
  transition:background .2s;
}
.btn-join:hover{background:var(--red2);}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">
    <div class="logo-sq"></div>
    API SIPUTZX
  </a>
  <button class="nav-menu-btn" onclick="openMenu()" aria-label="Menu">
    <span></span><span></span>
  </button>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="status-pill">
    <span class="status-dot"></span>
    SYSTEM OPERATIONAL: V.2.0.0
  </div>
  <h1 class="hero-title">
    NO LOGIN.<br>
    NO KEY.<br>
