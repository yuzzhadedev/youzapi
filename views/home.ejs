    </div>
    <div class="feat-card">
      <span class="feat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </span>
      <div class="feat-title">GLOBAL NETWORK</div>
      <ul class="feat-list">
        <li>LATENCY &lt; 100MS</li>
        <li>99.9% UPTIME</li>
