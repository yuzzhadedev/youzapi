      </ul>
    </div>
    <div class="feat-card">
      <span class="feat-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28"><path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
      </span>
      <div class="feat-title">DEVELOPER FIRST</div>
      <ul class="feat-list">
        <li>CLEAN JSON RESPONSES</li>
        <li>OPEN DOCUMENTATION</li>
        <li>INSTANT ACCESS</li>
      </ul>
    </div>
  </div>
</section>

<!-- ENDPOINT CATALOG -->
<section class="catalog-section">
  <div class="catalog-heading">
    <h2>ENDPOINT <span>CATALOG</span></h2>
  </div>
  <div class="cat-scroll">
    <a href="playground.html" class="cat-card">
      <div class="cat-icon-wrap">AI</div>
      <div class="cat-title">ARTIFICIAL INTELLIGENCE</div>
      <div class="cat-sub">DuckAI, Blackbox, Claude.</div>
    </a>
    <a href="playground.html" class="cat-card">
      <div class="cat-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      </div>
      <div class="cat-title">MEDIA DOWNLOADER</div>
      <div class="cat-sub">TikTok, IG, YouTube, Spotify, Twitter.</div>
    </a>
    <a href="playground.html" class="cat-card">
      <div class="cat-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
      </div>
      <div class="cat-title">SEARCH ENGINE</div>
      <div class="cat-sub">Google, YouTube, Wikipedia.</div>
    </a>
    <a href="playground.html" class="cat-card">
      <div class="cat-icon-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
